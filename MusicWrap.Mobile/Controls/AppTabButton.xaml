<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MusicWrap.Mobile.Controls.AppTabButton"
             x:Name="self"
             >
    <Border BackgroundColor="Transparent"
            StrokeThickness="0"
            Padding="0,0,0,0">
        <VerticalStackLayout VerticalOptions="Start"
                             HorizontalOptions="Center"
                             Spacing="4">
            <!-- Indicator -->
            <BoxView x:Name="Indicator"
                     HeightRequest="2"
                     WidthRequest="24"
                     CornerRadius="1"
                     Margin="0,0,0,8"
                     HorizontalOptions="Center"/>
            <!-- Icon -->
            <Label x:Name="IconLabel"
                   FontFamily="{Binding Source={x:Reference self}, Path=IconFontFamily}"
                   FontSize="20"
                   HorizontalOptions="Center" />
            <!-- Text -->
            <Label x:Name="TextLabel"
                   Text="{Binding Source={x:Reference self}, Path=Text}"
                   FontSize="10"
                   HorizontalOptions="Center" />
        </VerticalStackLayout>
    </Border>
</ContentView>
