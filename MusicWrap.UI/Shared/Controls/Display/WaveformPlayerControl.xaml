<UserControl x:Class="MusicWrap.UI.Controls.WaveformPlayerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MusicWrap.UI.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="800"
             Loaded="UserControl_Loaded"
             SizeChanged="UserControl_SizeChanged"
             PreviewKeyDown="UserControl_PreviewKeyDown"
             Focusable="True"
             >
    <Border Padding="2">
        <Grid x:Name="WaveformContainer">
            <!-- Back waveform -->
            <Path x:Name="PathBackground" StrokeThickness="1" Fill="White" Stretch="Fill" Opacity="0.25"/>
            <!-- Front filled waveform -->
            <Path x:Name="PathForeground" 
                  StrokeThickness="1" 
                  Fill="{Binding DominantColorHex, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource HexToBrushConverter}}" 
                  Stretch="Fill">
                <Path.Clip>
                    <RectangleGeometry x:Name="ProgressClip" Rect="0,0,0,0"/>
                </Path.Clip>
            </Path>

            <Line x:Name="PositionThumb"
              Stroke="White"
              StrokeThickness="1"
              SnapsToDevicePixels="True"
              IsHitTestVisible="False"
              Visibility="Collapsed"
            />
            <Popup
                x:Name="SeekPopup"
                Placement="Relative"
                PlacementTarget="{Binding ElementName=WaveformContainer}"
                StaysOpen="True"
                AllowsTransparency="True"
                IsHitTestVisible="False"
                IsOpen="False"
                >
                <Border 
                    Background="{StaticResource BackgroundFloating}" 
                    BorderThickness="1" 
                    BorderBrush="{StaticResource StrokeFloating}"
                    CornerRadius="4"
                    Padding="8,4"
                    >
                    <TextBlock x:Name="SeekPopupText" Foreground="White" FontSize="11" Text="0:00" />
                </Border>
            </Popup>

            <!-- Interactive layer-->
            <Rectangle 
                Fill="Transparent"
                MouseDown="Rectangle_MouseDown"
                MouseMove="Rectangle_MouseMove"
                MouseUp="Rectangle_MouseUp"
                MouseRightButtonDown="Rectangle_MouseRightButtonDown"
                   />
        </Grid>
    </Border>
</UserControl>


