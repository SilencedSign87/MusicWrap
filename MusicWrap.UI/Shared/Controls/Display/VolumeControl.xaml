<UserControl x:Class="MusicWrap.UI.Controls.VolumeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MusicWrap.UI.Controls"
             xmlns:vm="clr-namespace:MusicWrap.UI.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:PlayerViewModel}"
             Loaded="UserControl_Loaded"
             SizeChanged="UserControl_SizeChanged"
             d:DesignHeight="32" d:DesignWidth="200">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Button 
            Grid.Column="0"
            VerticalAlignment="Center"
            Foreground="{Binding DominantColorHex, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource HexToBrushConverter}}" 
            Style="{StaticResource SubtleButton}" Width="32" Height="32" Padding="1"  Command="{Binding ToggleMuteCommand}"
        >
            <TextBlock FontFamily="Segoe Fluent Icons" Text="{Binding MuteButtonIcon}" d:Text="&#xE767;" FontSize="16"/>
        </Button>
        <Border Grid.Column="2">
            <Grid x:Name="VolumeContainer">
                <Path x:Name="PathBackground" 
                        Fill="{Binding DominantColorHex, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource HexToBrushConverter}}"
                        Opacity="0.18"
                      Stretch="Fill"/>
                
                <Path x:Name="PathForeground" 
                      Fill="{Binding DominantColorHex, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource HexToBrushConverter}}" 
                      Stretch="Fill">
                    <Path.Clip>
                        <RectangleGeometry x:Name="VolumeClip" Rect="0,0,0,0"/>
                    </Path.Clip>
                </Path>

                <Popup
                    x:Name="VolumePopup"
                    Placement="Relative"
                    PlacementTarget="{Binding ElementName=VolumeContainer}"
                    StaysOpen="True"
                    AllowsTransparency="True"
                    IsHitTestVisible="False"
                    IsOpen="False"
                    >
                    <Border
                        Background="{StaticResource BackgroundFloating}"
                        BorderThickness="1"
                        BorderBrush="{StaticResource StrokeFloating}"
                        CornerRadius="4"
                        Padding="8,4"
                        >
                        <TextBlock x:Name="VolumePopupText" Foreground="White" FontSize="11" Text="0" />
                    </Border>
                </Popup>
                
                <!-- Interactive layer-->
                <Rectangle
                    x:Name="InteractiveLayer"
                    Fill="Transparent"
                    MouseDown="InteractiveLayer_MouseDown"
                    MouseUp="InteractiveLayer_MouseUp"
                    MouseMove="InteractiveLayer_MouseMove"
                    MouseLeave="InteractiveLayer_MouseLeave"
                />
            </Grid>
        </Border>
    </Grid>
</UserControl>
