<UserControl x:Class="MusicWrap.UI.Controls.VolumeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:MusicWrap.UI.Shared.Controls.ViewModel"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:VolumeControlViewModel}"
             Loaded="UserControl_Loaded"
             SizeChanged="UserControl_SizeChanged"
             d:DesignHeight="32" d:DesignWidth="200">

    <Grid x:Name="RootLayout">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="ColButton" Width="Auto"/>
            <ColumnDefinition x:Name="ColSpacer" Width="4"/>
            <ColumnDefinition x:Name="ColVolume" Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition x:Name="RowVolume" Height="*"/>
            <RowDefinition x:Name="RowSpacer" Height="0"/>
            <RowDefinition x:Name="RowButton" Height="0"/>
        </Grid.RowDefinitions>

        <Button x:Name="MuteButton"
                Grid.Row="0" Grid.Column="0"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Width="32" Height="32"
                Padding="1"
                Style="{StaticResource SubtleButton}"
                Foreground="{Binding DominantColorHex, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource HexToBrushConverter}}"
                Command="{Binding ToggleMuteCommand}">
            <TextBlock FontFamily="Segoe Fluent Icons"
                       Text="{Binding MuteButtonIcon}"
                       d:Text="&#xE767;"
                       FontSize="16"/>
        </Button>

        <Border x:Name="LayoutSpacer"
                Grid.Row="0" Grid.Column="1"
                Background="Transparent"/>

        <Border x:Name="VolumeHost"
                Grid.Row="0" Grid.Column="2">
            <Grid x:Name="VolumeContainer" Background="Transparent">

                <!-- Track Background (unfilled portion) -->
                <Rectangle x:Name="TrackBackground"
                           Fill="{Binding DominantColorHex, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource HexToBrushConverter}}"
                           Opacity="0.18"
                           RadiusX="2" RadiusY="2"/>

                <!-- Track Foreground (filled portion) -->
                <Rectangle x:Name="TrackForeground"
                           Fill="{Binding DominantColorHex, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource HexToBrushConverter}}"
                           RadiusX="2" RadiusY="2"/>

                <!-- Thumb -->
                <Rectangle x:Name="Thumb"
                           Fill="{Binding DominantColorHex, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource HexToBrushConverter}}"
                           RadiusX="2" RadiusY="2"/>

                <!-- Interactive Layer -->
                <Rectangle x:Name="InteractiveLayer"
                           Fill="Transparent"
                           MouseDown="InteractiveLayer_MouseDown"
                           MouseUp="InteractiveLayer_MouseUp"
                           MouseMove="InteractiveLayer_MouseMove"
                           MouseLeave="InteractiveLayer_MouseLeave"/>

                <!-- Volume Popup (visible only during drag) -->
                <Popup x:Name="VolumePopup"
                       Placement="Relative"
                       PlacementTarget="{Binding ElementName=VolumeContainer}"
                       StaysOpen="True"
                       AllowsTransparency="True"
                       IsHitTestVisible="False"
                       IsOpen="False">
                    <Border Background="{StaticResource BackgroundFloating}"
                            BorderThickness="1"
                            BorderBrush="{StaticResource StrokeFloating}"
                            CornerRadius="4"
                            Padding="8,4">
                        <TextBlock x:Name="VolumePopupText"
                                   Foreground="White"
                                   FontSize="11"
                                   Text="0"/>
                    </Border>
                </Popup>

            </Grid>
        </Border>
    </Grid>
</UserControl>
