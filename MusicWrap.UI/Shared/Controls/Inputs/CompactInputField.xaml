<UserControl x:Class="MusicWrap.UI.Controls.CompactInputField"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MusicWrap.UI.Controls"
             x:Name="Root"
             mc:Ignorable="d" 
             d:DesignHeight="32" d:DesignWidth="120">
    <Border x:Name="Container"
            CornerRadius="0"
            BorderThickness="1"
            Padding="0"
            Margin="0"
            Background="{StaticResource BackgroundControlDefault}"
            BorderBrush="{StaticResource StrokeControl}">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="{StaticResource BackgroundControlDefault}" />
                <Setter Property="BorderBrush" Value="{StaticResource StrokeControl}" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource BackgroundControlHover}" />
                        <Setter Property="BorderBrush" Value="{StaticResource StrokeDivider}" />
                    </Trigger>
                    <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=Root}" Value="True">
                        <Setter Property="Background" Value="{StaticResource BackgroundControlPressed}" />
                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush100}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsEnabled, ElementName=Root}" Value="False">
                        <Setter Property="Opacity" Value="0.55" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ContentPresenter Grid.Column="0"
                              Content="{Binding BeforeContent, ElementName=Root}"
                              VerticalAlignment="Center"
                              >
                <ContentPresenter.Style>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Margin" Value="6,0,2,0"/>
                        <Style.Triggers>
                            <Trigger Property="Content" Value="{x:Null}">
                                <Setter Property="Margin" Value="0"/>

                            </Trigger>
                        </Style.Triggers>
                        
                    </Style>
                </ContentPresenter.Style>
            </ContentPresenter>

            <Grid Grid.Column="1">
                <TextBox x:Name="InputBox"
                         VerticalContentAlignment="Center"
                         FocusVisualStyle="{x:Null}"
                         KeyDown="InputBox_KeyDown"
                         TextChanged="InputBox_TextChanged"
                         PreviewTextInput="InputBox_PreviewTextInput"
                         DataObject.Pasting="InputBox_Pasting"
                         LostKeyboardFocus="InputBox_LostKeyboardFocus"
                         PreviewKeyDown="InputBox_PreviewKeyDown"
                         Text="{Binding Text, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource TransparentTextInput}">
                            <Setter Property="Margin" Value="2,0,2,0"/>

                            <Style.Triggers>
                                <!-- no before -->
                                <DataTrigger Binding="{Binding BeforeContent, ElementName=Root}" Value="{x:Null}">
                                    <Setter Property="Margin" Value="4,0,2,0"/>
                                </DataTrigger>

                                <!-- no after -->
                                <DataTrigger Binding="{Binding AfterContent, ElementName=Root}" Value="{x:Null}">
                                    <Setter Property="Margin" Value="2,0,4,0"/>
                                </DataTrigger>

                                <!-- no before and no after -->
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding BeforeContent, ElementName=Root}" Value="{x:Null}" />
                                        <Condition Binding="{Binding AfterContent, ElementName=Root}" Value="{x:Null}" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Margin" Value="0"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <TextBlock Text="{Binding PlaceholderText, ElementName=Root}"
                           Margin="4,0,0,0"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Foreground="#80FFFFFF"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding Text, ElementName=InputBox}" Value="" />
                                        <Condition Binding="{Binding IsKeyboardFocused, ElementName=InputBox}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <ContentPresenter Grid.Column="2"
                              Content="{Binding AfterContent, ElementName=Root}"
                              VerticalAlignment="Center"
                              >
                <ContentPresenter.Style>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Margin" Value="2,0,6,0"/>
                        <Style.Triggers>
                            <Trigger Property="Content" Value="{x:Null}">
                                <Setter Property="Margin" Value="0"/>

                            </Trigger>
                        </Style.Triggers>

                    </Style>
                </ContentPresenter.Style>
            </ContentPresenter>
        </Grid>
    </Border>
</UserControl>


