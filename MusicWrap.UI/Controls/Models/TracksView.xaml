<UserControl x:Class="MusicWrap.UI.Controls.Models.TracksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MusicWrap.UI.Controls.Models"
             xmlns:ex="clr-namespace:MusicWrap.UI.Helpers"
             xmlns:converters="clr-namespace:MusicWrap.UI.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <converters:ForegroundIsLightConverter x:Key="ForegroundIsLightConverter"/>
        <ItemsPanelTemplate x:Key="VirtualizedItemsPanel">
            <VirtualizingStackPanel/>
        </ItemsPanelTemplate>

        <ItemsPanelTemplate x:Key="ColumnFlowItemsPanel">
            <ex:ColumnFlowPanel 
                ex:ColumnFlowPanel.Columns="{Binding RelativeSource={RelativeSource AncestorType=local:TracksView}, Path=ColumnFlowColumns}"
                />
        </ItemsPanelTemplate>

        <Style x:Key="TracksListBoxStyle" TargetType="{x:Type ListBox}">
            <Setter Property="ItemsPanel" Value="{StaticResource VirtualizedItemsPanel}"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=local:TracksView}, Path=UseColumnFlowPanel}" Value="True">
                    <Setter Property="ItemsPanel" Value="{StaticResource ColumnFlowItemsPanel}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TrackItemContainerStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType=local:TracksView}, Path=Foreground}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border
                    x:Name="Root"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    SnapsToDevicePixels="True">
                            <ContentPresenter
                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                        Margin="{TemplateBinding Padding}"
                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsMouseOver" Value="True"/>
                        <Condition Property="IsSelected" Value="False"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#1f000000"/>
                </MultiTrigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=local:TracksView}, Path=Foreground, Converter={StaticResource ForegroundIsLightConverter}}" Value="True"/>
                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsSelected}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#FFFFFFFF"/>
                    <Setter Property="Foreground" Value="#FF000000"/>
                </MultiDataTrigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=local:TracksView}, Path=Foreground, Converter={StaticResource ForegroundIsLightConverter}}" Value="False"/>
                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsSelected}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#FF000000"/>
                    <Setter Property="Foreground" Value="#FFFFFFFF"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="TrackItemTemplate" DataType="local:TrackRowItem">
            <Grid Margin="0,2" Cursor="Hand">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto" MinWidth="50"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0" FontSize="13" Opacity="0.6" >
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Setter Property="Text" Value=""/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=local:TracksView}, Path=IndexMode}" Value="{x:Static local:TrackIndexDisplayMode.ListIndex}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Setter Property="Text" Value="{Binding ListIndex}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=local:TracksView}, Path=IndexMode}" Value="{x:Static local:TrackIndexDisplayMode.TrackNumber}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Setter Property="Text" Value="{Binding TrackNumberDisplay}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <Border Grid.Column="1" Width="38" Height="38" Margin="0,0,8,0" CornerRadius="2">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=local:TracksView}, Path=VisualMode}" Value="{x:Static local:TrackVisualMode.WithCoverArt}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Image Source="{Binding CoverAssetPath, Converter={StaticResource PathToImageConverter}, ConverterParameter=42}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="LowQuality"/>
                </Border>

                <Grid Grid.Column="2" HorizontalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="12" FontWeight="Medium" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>

                    <TextBlock Grid.Row="1" Text="{Binding ArtistNames}" FontSize="12" Opacity="0.65" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                </Grid>

                <TextBlock Grid.Column="3" Text="{Binding DurationText}" VerticalAlignment="Center" Margin="16,0,0,0" FontSize="12" Opacity="0.6"/>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <ListView x:Name="TracksList" 
                 Style="{StaticResource TracksListBoxStyle}" 
                 ItemContainerStyle="{StaticResource TrackItemContainerStyle}" 
                 ItemTemplate="{StaticResource TrackItemTemplate}" 
                 ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=local:TracksView}, Path=ItemsSource}" 
                 SelectionMode="{Binding RelativeSource={RelativeSource AncestorType=local:TracksView}, Path=SelectionMode}" 
                 SelectionChanged="TracksList_SelectionChanged"
                 MouseDoubleClick="TracksList_MouseDoubleClick" 
                 KeyDown="TracksList_KeyDown" 
                 PreviewMouseWheel="TracksList_PreviewMouseWheel"
                 PreviewMouseRightButtonDown="TracksList_PreviewMouseRightButtonDown"
                 ScrollViewer.CanContentScroll="False"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                 Background="Transparent" BorderThickness="0">
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Play Now" Icon="{ex:Icon Glyph=E768}" x:Name="PlayNowButton" Click="PlayNowButton_Click" />
                    <MenuItem Header="Play Next" Icon="{ex:Icon Glyph=E893}" x:Name="PlayNextButton" Click="PlayNextButton_Click" />
                    <Separator/>
                    <MenuItem Header="Add to Queue" Icon="{ex:Icon Glyph=E710}" x:Name="AddQueueButton" Click="AddQueueButton_Click" />
                    <MenuItem Header="Add to playlist" Icon="{ex:Icon Glyph=E142}" x:Name="AddToPlaylist" Click="AddToPlaylist_Click" />
                    <Separator/>
                    <MenuItem Header="Edit track" Icon="{ex:Icon Glyph=E70F}" x:Name="EditButton" Click="EditButton_Click" />
                    <MenuItem Header="Remove track" Icon="{ex:Icon Glyph=E74D}" x:Name="RemoveButton" Click="RemoveButton_Click" />
                    <Separator/>
                    <MenuItem Header="Show in File Explorer" Icon="{ex:Icon Glyph=E8B7}" x:Name="ShowExternal" Click="ShowExternal_Click" />
                </ContextMenu>
            </ListView.ContextMenu>
        </ListView>
    </Grid>
</UserControl>
