<Application x:Class="MusicWrap.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MusicWrap.UI"
             xmlns:converters="clr-namespace:MusicWrap.UI.Converters"
             xmlns:ex="clr-namespace:MusicWrap.UI.Helpers"
             xmlns:tb="http://www.hardcodet.net/taskbar"
             ThemeMode="Dark"
             ShutdownMode="OnExplicitShutdown"
             >
    <Application.Resources>

        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!--<ResourceDictionary Source="pack://application:,,,/PresentationFramework.Fluent;component/Themes/Fluent.xaml" />-->
                <ResourceDictionary Source="/Styles/Resources.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Global Converters -->
            <converters:PathToImageConverter x:Key="PathToImageConverter"/>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <converters:HexToBrushConverter x:Key="HexToBrushConverter"/>
            <converters:TypeNameConverter x:Key="TypeNameConverter"/>
            <converters:DiskNumberToVisibilityConverter x:Key="DiskNumberToVisibilityConverter"/>
            <converters:NullToVisibilityConverter x:Key="NullToCollapseConverter" />
            <converters:SelectedAlbumBackgroundConverter x:Key="SelectedAlbumBackgroundConverter"/>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <converters:ForegroundIsLightConverter x:Key="ForegroundIsLightConverter"/>
            <converters:TabStringToVisibilityConverter x:Key="TabStringToVisibilityConverter"/>

            <tb:TaskbarIcon
                x:Key="TrayIcon"
                IconSource="/Resources/icon.ico"
                ToolTipText="MusicWrap"
                >
                <tb:TaskbarIcon.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Open MusicWrap" Icon="{ex:Icon Glyph=E8A7}" Command="{Binding OpenMainWindowCommand}"/>
                        <Separator/>
                        <MenuItem Header="{Binding PlayPauseStatus}" Command="{Binding TogglePlayPauseCommand}">
                            <MenuItem.Icon>
                                <TextBlock FontFamily="{StaticResource SymbolThemeFontFamily}" Text="{Binding PlayPauseIcon}"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Stop" Icon="{ex:Icon Glyph=E71A}" Command="{Binding StopCommand}"/>
                        <MenuItem Header="Next" Icon="{ex:Icon Glyph=E893}" Command="{Binding NextCommand}"/>
                        <MenuItem Header="Previous" Icon="{ex:Icon Glyph=E892}" Command="{Binding PreviousCommand}"/>
                        <MenuItem Header="Shuffle" Icon="{ex:Icon Glyph=E8B1}" Command="{Binding ShuffleCommand}"/>
                        <MenuItem Header="More information" Icon="{ex:Icon Glyph=E946}" Command="{Binding InfoCommand}"/>
                        <Separator/>
                        <MenuItem Header="Exit" Icon="{ex:Icon Glyph=E711}" Command="{Binding ExitAppCommand}"/>
                    </ContextMenu>
                </tb:TaskbarIcon.ContextMenu>
            </tb:TaskbarIcon>
        </ResourceDictionary>


    </Application.Resources>
</Application>
