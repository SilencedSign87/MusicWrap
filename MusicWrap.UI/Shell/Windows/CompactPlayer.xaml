<Window x:Class="MusicWrap.UI.Shell.Windows.CompactPlayer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MusicWrap.UI.Shell.Windows"
        xmlns:mw="clr-namespace:MusicWrap.UI.Features.Playback.Views"
        xmlns:controls="clr-namespace:MusicWrap.UI.Controls"
        xmlns:vm="clr-namespace:MusicWrap.UI.ViewModels"
        x:Name="MusicWrapCompactWindow"
        d:DataContext="{d:DesignInstance Type=vm:PlayerViewModel}"
        mc:Ignorable="d"
        Icon="/Resources/icon.ico" 
        Title="MusicWrap" 
        Width="250" 
        Height="320"
        d:Height="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Foreground="{Binding CurrentTrackForegroundColorHex, Converter={StaticResource HexToBrushConverter}, ConverterParameter=foreground}"
        d:Background="#2c2c2c"
        d:Foreground="White"
        >
    <Window.Background>
        <ImageBrush 
            ImageSource="{Binding CurrentTrackImagePath , Converter={StaticResource PathToImageConverter}, ConverterParameter=blur:512}" 
            RenderOptions.BitmapScalingMode="HighQuality"
            Stretch="UniformToFill"/>
    </Window.Background>
    <Window.Resources>
        <Style x:Key="CompactPlayerButton" TargetType="Button" BasedOn="{StaticResource SubtleButton}" >
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Foreground" Value="{Binding CurrentTrackForegroundColorHex, Converter={StaticResource HexToBrushConverter}, ConverterParameter=foreground}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{Binding CurrentTrackDominantColorHex, Converter={StaticResource HexToBrushConverter}, ConverterParameter=background}"/>
                    <Setter Property="Background" Value="{Binding CurrentTrackForegroundColorHex, Converter={StaticResource HexToBrushConverter}, ConverterParameter=foreground}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CompactClosePlayerButton" TargetType="Button" BasedOn="{StaticResource CloseButton}" >
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Foreground" Value="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Window}}"/>
        </Style>
        <Style x:Key="TitlebarButton" TargetType="Button" BasedOn="{StaticResource CompactPlayerButton}">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=Titlebar, Path=IsMouseOver}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="TitlebarCloseButton" TargetType="Button" BasedOn="{StaticResource CompactClosePlayerButton}">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=Titlebar, Path=IsMouseOver}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome
        CaptionHeight="250"
        ResizeBorderThickness="6"
        CornerRadius="8"
        GlassFrameThickness="1"
        UseAeroCaptionButtons="False"
        />
    </WindowChrome.WindowChrome>
    <Border>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="250"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <!--Artwork-->
            <Grid Grid.Row="0" x:Name="ArtworkArea">
                <Image
                    x:Name="ArtworkImage"
                    Source="{Binding CurrentTrackImagePath , Converter={StaticResource PathToImageConverter}, ConverterParameter=large:250}"
                    Width="250"
                    RenderOptions.BitmapScalingMode="HighQuality"
                    />
                <StackPanel 
                    x:Name="Titlebar"
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Top" 
                    WindowChrome.IsHitTestVisibleInChrome="True"
                    Background="Transparent"
                    Height="32"
                    Width="128">
                    <Button Style="{StaticResource TitlebarButton}" Width="32" Height="32" Click="HandleToggleAllwayOnTop">
                        <TextBlock x:Name="PinIconFont" FontFamily="Segoe Fluent Icons" Text="&#xe718;" FontSize="13" />
                    </Button>
                    <Button Style="{StaticResource TitlebarButton}" Width="32" Height="32" Click="MinimizeClick" ToolTip="Minimize">
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE921;" FontSize="10" />
                    </Button>
                    <Button Style="{StaticResource TitlebarButton}" Width="32" Height="32" ToolTip="Open main player" Click="HandleOpenMainPlayer">
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE92D;" FontSize="10" />
                    </Button>
                    <Button Style="{StaticResource TitlebarCloseButton}" Width="32" Height="32" Click="HandleCloseApp" ToolTip="Close">
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE8BB;" FontSize="10" />
                    </Button>
                </StackPanel>
            </Grid>
            <!--Controls-->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="8,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32" />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" 
                            Text="{Binding FormattedPosition, ElementName=WaveFormPlayer, Mode=OneWay}" 
                            FontWeight="Light" 
                            FontSize="11" 
                            VerticalAlignment="Center"/>
                        <Grid Grid.Column="1" Margin="8,4">
                            <controls:WaveformPlayerControl
                                x:Name="WaveFormPlayer"
                                DominantColorHex="{Binding CurrentTrackForegroundColorHex}"
                            />
                        </Grid>
                        <TextBlock Grid.Column="2" 
                            Text="{Binding FormattedDuration, ElementName=WaveFormPlayer, Mode=OneWay}" 
                            FontWeight="Light" 
                            FontSize="11" 
                            VerticalAlignment="Center"/>
                    </Grid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="MoreButton" Style="{StaticResource CompactPlayerButton}" Padding="0" ToolTip="Queue/Library" Click="HandleOpenQueue">
                            <TextBlock x:Name="PanelIcon" FontFamily="Segoe Fluent Icons" Text="&#xE70D;" FontSize="14"/>
                        </Button>
                        <Button x:Name="RepeadButton" Style="{StaticResource CompactPlayerButton}" Padding="0" ToolTip="{Binding RepeatModeTooltip}" Command="{Binding CicleRepeatModeCommand}">
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="{Binding RepeatModeIcon}" FontSize="14"/>
                        </Button>
                        <Button x:Name="PrevButton" Style="{StaticResource CompactPlayerButton}" Padding="0" ToolTip="Previous track"
                            Command="{Binding PreviousCommand}">
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe892;" FontSize="14"/>
                        </Button>
                        <Button x:Name="PlayButton" Style="{StaticResource CompactPlayerButton}" Padding="0"
                            Command="{Binding PlayPauseCommand}">
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="{Binding PlayPauseIcon}" FontSize="16"/>
                        </Button>
                        <Button x:Name="NextButton" Style="{StaticResource CompactPlayerButton}" Padding="0" ToolTip="Next track"
                            Command="{Binding NextCommand}">
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe893;" FontSize="14"/>
                        </Button>
                        <Button x:Name="ShuffleButton" Style="{StaticResource CompactPlayerButton}" Padding="0" ToolTip="{Binding ShuffleTooltip}" Command="{Binding ToggleShuffleCommand}">
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="{Binding ShuffleIcon}" FontSize="14"/>
                        </Button>
                        <Button x:Name="VolumeButton" Click="VolumeButton_Click" Style="{StaticResource CompactPlayerButton}" Padding="0" ToolTip="Volume">
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE767;" FontSize="14"/>
                        </Button>
                    </StackPanel>
                    <Popup
                         x:Name="VolumePopup"
                         PlacementTarget="{Binding ElementName=VolumeButton}"
                         Placement="Center"
                         PopupAnimation="None"
                         AllowsTransparency="True"
                         StaysOpen="False">
                        <Border>
                            <Border 
                                Background="{Binding CurrentTrackDominantColorHex}" 
                                BorderBrush="{StaticResource StrokeFloating}" 
                                CornerRadius="8" 
                                Margin="8,16"
                                Padding="8,4"
                                BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000"
                                        BlurRadius="16"
                                        ShadowDepth="4"
                                        Direction="270"
                                        Opacity="0.5"/>
                                </Border.Effect>
                                <StackPanel>
                                    <controls:VolumeControl
                                        DominantColorHex="{Binding DataContext.CurrentTrackForegroundColorHex, ElementName=MusicWrapCompactWindow, Converter={StaticResource HexToBrushConverter}}"
                                        Width="150"
                                        Height="32"/>
                                </StackPanel>
                            </Border>
                        </Border>
                    </Popup>
                </Grid>
                <Grid
                    Grid.Row="1"
                    x:Name="QueuePanel"
                    Visibility="Collapsed"
                    d:Visibility="Visible">
                    <TabControl Style="{StaticResource SubtleTabControl}" >
                        <TabItem Style="{StaticResource SubtleTabItem}" Foreground="{Binding CurrentTrackForegroundColorHex, Converter={StaticResource HexToBrushConverter}}">
                            <TabItem.Header>
                                <StackPanel>
                                    <TextBlock Text="Queue" />
                                </StackPanel>
                            </TabItem.Header>

                            <mw:QueueListPage />
                        </TabItem>
                        <TabItem Style="{StaticResource SubtleTabItem}" Foreground="{Binding CurrentTrackForegroundColorHex, Converter={StaticResource HexToBrushConverter}}">
                            <TabItem.Header>
                                <StackPanel>
                                    <TextBlock Text="Library" />
                                </StackPanel>
                            </TabItem.Header>

                        </TabItem>
                    </TabControl>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>


