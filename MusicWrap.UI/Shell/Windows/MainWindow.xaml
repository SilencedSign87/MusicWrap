<Window x:Class="MusicWrap.UI.Shell.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MusicWrap.UI"
        xmlns:pages="clr-namespace:MusicWrap.UI.Features.Playback.Views"
        xmlns:ex="clr-namespace:MusicWrap.UI.Helpers"
        xmlns:controls="clr-namespace:MusicWrap.UI.Controls"
        xmlns:nav="clr-namespace:MusicWrap.UI.Shared.Controls.Navigation"
        xmlns:mw="clr-namespace:MusicWrap.UI.Features.Playback.Views"
        xmlns:vm="clr-namespace:MusicWrap.UI.Shell.ViewModel"
        xmlns:shellControls="clr-namespace:MusicWrap.UI.Shell.Controls"
        mc:Ignorable="d"
        x:Name="MainWindowRoot"
        Icon="/Resources/icon.ico"
        Title="MusicWrap"
        Height="800"
        Width="1200"
        MinHeight="670"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        d:Background="#000000"
        ResizeMode="CanResize"
        ThemeMode="Dark"
        KeyDown="MainWindowRoot_KeyDown"
        d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel}"
        >
    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="32"
            CornerRadius="12"
            GlassFrameThickness="-1"
            ResizeBorderThickness="4"
            UseAeroCaptionButtons="True"
            NonClientFrameEdges="None"
            />
    </WindowChrome.WindowChrome>
    <Window.TaskbarItemInfo>
        <TaskbarItemInfo>
            <TaskbarItemInfo.ThumbButtonInfos>
                <ThumbButtonInfo
                    Description="Previous track"
                    ImageSource="/Resources/Icons/PreviousIcon.png"
                    Command="{Binding PreviousCommand}"
                    />
                <ThumbButtonInfo
                    ImageSource="{Binding PlayPauseIcon}"
                    Description="Play"
                    Command="{Binding PlayPauseCommand}"
                    />
                <ThumbButtonInfo
                    Description="Next track"
                    ImageSource="/Resources/Icons/NextIcon.png"
                    Command="{Binding NextCommnad}"
                    />
            </TaskbarItemInfo.ThumbButtonInfos>
        </TaskbarItemInfo>
    </Window.TaskbarItemInfo>

    <!--Window-->
    <Border
        x:Name="BorderWindow"
        >
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />
                <RowDefinition Height="*" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>
            <!--Titlebar-->
            <Grid Grid.Row="0" Margin="0,0,144,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0" HorizontalAlignment="Left">
                    <Image
                        Source="/Resources/MusicUI.png"
                        Width="20"
                        Height="20"
                        Margin="8,4,4,4"
                        RenderOptions.BitmapScalingMode="HighQuality"
                        />
                    <nav:ShellTabControl 
                        x:Name="SystemTabs" 
                        SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        CompactWidthThreshold="1100">
                        <nav:ShellTabItem Icon="&#xe8f1;" Text="Library" TabIndex="0" ToolTip="Library"/>
                        <nav:ShellTabItem Icon="&#xe90b;" Text="Playlists" TabIndex="1" ToolTip="Playlists"/>
                        <nav:ShellTabItem Icon="&#xECAA;" Text="Services" TabIndex="2" ToolTip="Services"/>
                        <nav:ShellTabItem Icon="&#xF61F;" Text="Now Playing" TabIndex="3" ToolTip="Now Playing"/>
                    </nav:ShellTabControl>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Column="1" ClipToBounds="True" WindowChrome.IsHitTestVisibleInChrome="True">
                    <controls:CommandPaletteInput VerticalAlignment="Center" Width="200" Height="32" PlaceholderText="Search..."/>
                    <Border Margin="2,4,0,4" Width="1" Background="#333"/>

                    <controls:ActivityButton/>

                    <Border Margin="0,4" Width="1" Background="#333"/>

                    <Button Style="{StaticResource TransparentTitleButton}" Command="{Binding openSettingsCommand}" ToolTip="Settings">
                        <TextBlock Text="&#xe713;" FontFamily="Segoe Fluent Icons" FontSize="16" />
                    </Button>
                    <Button Style="{StaticResource TransparentTitleButton}" Command="{Binding ToggleSidebarCommand}" ToolTip="{Binding SidebarTooltip}">
                        <TextBlock Text="{Binding SidebarToggleIcon}" FontFamily="Segoe Fluent Icons" FontSize="16" />
                    </Button>
                    <Button Style="{StaticResource TransparentTitleButton}" Command="{Binding showMiniplayerCommand}" ToolTip="MiniPlayer">
                        <TextBlock Text="&#xee49;" FontFamily="Segoe Fluent Icons" FontSize="16" />
                    </Button>
                    <Button Style="{StaticResource TransparentTitleButton}" Command="{Binding showFullScreenCommand}" ToolTip="Fullscreen">
                        <TextBlock Text="&#xE740;" FontFamily="Segoe Fluent Icons" FontSize="16"/>
                    </Button>
                    <Border Margin="0,4" Width="1" Background="#333"/>
                </StackPanel>

            </Grid>
            <!--Content-->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="{Binding SidebarWidth}" />
                </Grid.ColumnDefinitions>

                <!-- MainContent -->
                <ContentControl
                    Grid.Column="0"
                    Content="{Binding CurrentControl}"
                    />

                <!-- Sidebar -->
                <Border
                    Grid.Column="1"
                    BorderThickness="{Binding SidebarBorderThickness}"
                    >

                    <Grid
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Visibility="{Binding IsSidePanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <shellControls:SidebarControl Grid.Column="0" Grid.Row="0" />
                    </Grid>
                </Border>

            </Grid>
            
            <Grid Grid.Row="2" x:Name="PlayerContainer">
                <!--Player-->
            </Grid>
        </Grid>
    </Border>
</Window>


