<Window x:Class="MusicWrap.UI.Shell.Dialogs.MetadataEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MusicWrap.UI.Shell.Dialogs"
        xmlns:views="clr-namespace:MusicWrap.UI.Features.MetadataEditor.Views"
        xmlns:controls="clr-namespace:MusicWrap.UI.Controls"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        Icon="/Resources/icon.ico"
        d:Background="#080808"
        d:Foreground="White"
        Title="Metadata Editor" Height="500" Width="500">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <TabControl Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <TabItem Style="{StaticResource SubtleTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="{StaticResource SymbolThemeFontFamily}" Text="&#xE946;" VerticalAlignment="Center"/>
                        <TextBlock Text="Properties" Margin="8,0" />
                    </StackPanel>
                </TabItem.Header>
                <Grid>
                    <TextBlock Margin="12" Text="World" />
                </Grid>
            </TabItem>
            <TabItem IsSelected="True" Style="{StaticResource SubtleTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="{StaticResource SymbolThemeFontFamily}" Text="&#xE8EC;" VerticalAlignment="Center"/>
                        <TextBlock Text="Tags" Margin="8,0" />
                    </StackPanel>
                </TabItem.Header>
                <views:TagsEditor />
            </TabItem>
            <TabItem Style="{StaticResource SubtleTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="{StaticResource SymbolThemeFontFamily}" Text="&#xE8BA;" VerticalAlignment="Center"/>
                        <TextBlock Text="Artwork" Margin="8,0" />
                    </StackPanel>
                </TabItem.Header>
                <Grid>
                    <TextBlock Margin="12" Text="Is a lie." />
                </Grid>
            </TabItem>
        </TabControl>
        <StackPanel Grid.Row="1" HorizontalAlignment="Right" Margin="8" Orientation="Horizontal">
            <Button Margin="8,0" Style="{StaticResource AccentButton}">
                Save
            </Button>
            <Button Style="{StaticResource DefaultButton}">
                Cancel
            </Button>
        </StackPanel>
    </Grid>
</Window>


