<Window x:Class="MusicWrap.UI.Shell.Dialogs.NewPlaylistWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MusicWrap.UI.Shell.Dialogs"
        xmlns:controls="clr-namespace:MusicWrap.UI.Controls"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        d:Background="#202020"
        d:Foreground="White"

        Title="New Playlist" Height="132" Width="300">
    <Grid>
        <StackPanel>
            <controls:CompactInputField
                x:Name="PlaylistNameInput"
                Margin="10"
                PlaceholderText="Playlist name..."
                KeyDown="PlaylistNameInput_KeyDown"
                >
                <controls:CompactInputField.BeforeContent>
                    <TextBlock FontFamily="{StaticResource SymbolThemeFontFamily}" Text="&#xE90B;"/>
                </controls:CompactInputField.BeforeContent>
            </controls:CompactInputField>
            <Separator/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="8">
                <Button Content="Save" Style="{StaticResource AccentButton}" Margin="8,0" Click="SavePlaylist_Click"/>
                <Button Content="Cancel" Style="{StaticResource DefaultButton}" Click="CancelPlaylist_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>


