<Window x:Class="MusicWrap.UI.Shell.Dialogs.IntegrityReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MusicWrap.UI.Shell.ViewModel"
        xmlns:models="clr-namespace:MusicWrap.Core.Services.Library.Models;assembly=MusicWrap.Core"
        xmlns:controls="clr-namespace:MusicWrap.UI.Controls"
        mc:Ignorable="d"
        Title="Library report"
        Height="700" Width="500"
        ShowInTaskbar="False" ResizeMode="NoResize"
        ThemeMode="Dark" Icon="/Resources/icon.ico"
        d:DataContext="{d:DesignInstance Type=vm:IntegrityReportViewModel}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══════ HEADER ══════ -->
        <Border Grid.Row="0" Background="{StaticResource BackgroundLayer}" Padding="16,12">
            <StackPanel>
                <TextBlock FontSize="16" Foreground="White" Text="The following tracks are missing" />
                <TextBlock Text="{Binding AdditionalInfo}" FontSize="12" Foreground="#aaaaaa"
                           Visibility="{Binding AdditionalInfo, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
                <TextBlock FontSize="12" Foreground="#4caf50" Margin="0,2,0,0"
                           Visibility="{Binding AutoFixedCount, Converter={StaticResource ItemCountToVisibilityConverter}}">
                    <Run Text="{Binding AutoFixedCount}"/><Run Text=" track(s) auto-relocated"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ══════ RADIO BUTTONS ══════ -->
        <Border Grid.Row="1" Padding="16,12,16,4">
            <StackPanel Orientation="Horizontal">
                <RadioButton GroupName="bulkAction"
                             IsChecked="{Binding RemoveAllMissing}"
                             Content="Remove all"
                             FontSize="13" FontWeight="SemiBold" Foreground="White"
                             Margin="0,0,24,0"/>
                <RadioButton GroupName="bulkAction"
                             IsChecked="{Binding RemoveAllMissing, Converter={StaticResource InverseBoolConverter}}"
                             Content="Take actions"
                             FontSize="13" FontWeight="SemiBold" Foreground="White"/>
            </StackPanel>
        </Border>

        <!-- ══════ MISSING TRACKS LIST ══════ -->
        <Border Grid.Row="2" Margin="16,8,16,8"
                Background="{StaticResource BackgroundSmoke}" CornerRadius="4">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="IsEnabled" Value="True"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding RemoveAllMissing}" Value="True">
                            <Setter Property="Opacity" Value="0.5"/>
                            <Setter Property="IsEnabled" Value="False"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding MissingTracks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="models:MissingTrack">
                            <Border Padding="8,6" Margin="4,2" CornerRadius="4" Background="#2a2a2a">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" Foreground="White"/>
                                        <TextBlock FontSize="11" Foreground="#aaaaaa"
                                                   TextTrimming="CharacterEllipsis">
                                            <Run Text="{Binding ArtistNames, TargetNullValue='Unknown Artist'}"/>
                                            <Run Text=" — "/>
                                            <Run Text="{Binding AlbumName, TargetNullValue='Unknown Album'}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding ExpectedPath}" FontSize="10"
                                                   Foreground="#666666" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <!-- Action ComboBox -->
                                    <ComboBox Grid.Column="1"
                                              Width="110"
                                              VerticalAlignment="Center"
                                              SelectedIndex="0"
                                              SelectionChanged="ComboAction_SelectionChanged"
                                              Tag="{Binding}">
                                        <ComboBoxItem Tag="Remove">Remove</ComboBoxItem>
                                        <ComboBoxItem Tag="Locate">Locate...</ComboBoxItem>
                                        <ComboBoxItem Tag="Located" Visibility="Collapsed">Located ✓</ComboBoxItem>
                                    </ComboBox>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ══════ FOOTER ══════ -->
        <Border Grid.Row="3" Background="{StaticResource BackgroundLayer}" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Orphaned covers and duplicates will be cleaned up automatically."
                           VerticalAlignment="Center" Foreground="#888888" FontSize="11"/>

                <controls:AppButton
                    Grid.Column="2"
                    Style="{StaticResource AccentButton}"
                    Text="Confirm"
                    Command="{Binding ConfirmCommand}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
