<Window x:Class="MusicWrap.UI.Shell.Tray.TrayFlyoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MusicWrap.UI.Shell.Tray"
        xmlns:vm="clr-namespace:MusicWrap.UI.ViewModels"
        xmlns:controls="clr-namespace:MusicWrap.UI.Controls"
        mc:Ignorable="d"
        Title="Music Wrap" 
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Height="108" 
        x:Name="RootWindow"
        Width="350"
        WindowStyle="SingleBorderWindow"
        Foreground="{Binding CurrentTrackForegroundColorHex, Converter={StaticResource HexToBrushConverter}, ConverterParameter=foreground}"
        d:Background="#2c2c2c"
        d:Foreground="White"
        d:DataContext="{d:DesignInstance Type=vm:PlayerViewModel}"
        >
    <Window.Background>
        <ImageBrush 
         ImageSource="{Binding CurrentTrackImagePath , Converter={StaticResource PathToImageConverter}, ConverterParameter=blur:350}" 
         RenderOptions.BitmapScalingMode="HighQuality"
         Stretch="UniformToFill"/>
    </Window.Background>
    <Window.Resources>
        <Style x:Key="FlyoutTrayButton" TargetType="Button" BasedOn="{StaticResource TransparentButton}">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Foreground" Value="{Binding CurrentTrackForegroundColorHex, Converter={StaticResource HexToBrushConverter}, ConverterParameter=foreground}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{Binding CurrentTrackDominantColorHex, Converter={StaticResource HexToBrushConverter}, ConverterParameter=background}"/>
                    <Setter Property="Background" Value="{Binding CurrentTrackForegroundColorHex, Converter={StaticResource HexToBrushConverter}, ConverterParameter=foreground}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" 
                      GlassFrameThickness="1" 
                      CornerRadius="8" 
                      ResizeBorderThickness="4"/>
    </WindowChrome.WindowChrome>
    <Grid x:Name="RootPanel" Opacity="1">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="RootTranslate"/>
        </Grid.RenderTransform>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100" />
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="8"/>
        </Grid.RowDefinitions>
        <Image
                Grid.Row="0"
                Grid.Column="0"
                Source="{Binding CurrentTrackImagePath , Converter={StaticResource PathToImageConverter}, ConverterParameter=medium:100}"
                RenderOptions.BitmapScalingMode="LowQuality"
                />

        <Border Grid.Row="0" Grid.Column="2" Padding="8,8,8,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock FontSize="13" TextTrimming="CharacterEllipsis">
                            <Run Text="{Binding CurrentTrackTitle}" />
                        </TextBlock>
                        <TextBlock FontSize="11" Text="{Binding CurrentTrackArtists}" />
                        <TextBlock FontSize="10" HorizontalAlignment="Left">
                            <Run Text="{Binding FormattedPosition, ElementName=TrayWaveForm, Mode=OneWay}" />
                            <Run Text=" / " />
                            <Run Text="{Binding FormattedDuration, ElementName=TrayWaveForm, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <Button Style="{StaticResource FlyoutTrayButton}" ToolTip="Close" Click="ExitApp">
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE711;"/>
                        </Button>
                        <Button Style="{StaticResource FlyoutTrayButton}" ToolTip="Open MusicWrap" Click="OpenMainWindow">
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE8A7;"/>
                        </Button>
                    </StackPanel>
                </Grid>
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="RepeadButton" Style="{StaticResource FlyoutTrayButton}" Padding="0" ToolTip="{Binding RepeatModeTooltip}" Command="{Binding CicleRepeatModeCommand}">
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="{Binding RepeatModeIcon}" FontSize="14"/>
                    </Button>
                    <Button x:Name="PrevButton" Style="{StaticResource FlyoutTrayButton}" Padding="0" ToolTip="Previous track" Command="{Binding PreviousCommand}"
        >
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe892;" FontSize="14"/>
                    </Button>
                    <Button x:Name="PlayButton" Style="{StaticResource FlyoutTrayButton}" Padding="0" Command="{Binding PlayPauseCommand}"
        >
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="{Binding PlayPauseIcon}" FontSize="14"/>
                    </Button>
                    <Button x:Name="NextButton" Style="{StaticResource FlyoutTrayButton}" Padding="0" ToolTip="Next track" Command="{Binding NextCommand}"
        >
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe893;" FontSize="14"/>
                    </Button>
                    <Button x:Name="VolumeButton" Click="VolumeButton_Click" Style="{StaticResource FlyoutTrayButton}" Padding="0" ToolTip="Volume">
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE767;" FontSize="14"/>
                    </Button>
                </StackPanel>
                <Popup
                        x:Name="VolumePopup"
                        PlacementTarget="{Binding ElementName=VolumeButton}"
                        Placement="Center"
                        PopupAnimation="None"
                        AllowsTransparency="True"
                        StaysOpen="False">
                    <Border>
                        <Border 
                                Background="{Binding CurrentTrackDominantColorHex, Converter={StaticResource HexToBrushConverter}}" 
                                BorderBrush="{StaticResource StrokeFloating}" 
                                CornerRadius="8" 
                                Margin="8,16"
                                Padding="8,4"
                                BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000"
                                        BlurRadius="16"
                                        ShadowDepth="4"
                                        Direction="270"
                                        Opacity="0.5"/>
                            </Border.Effect>
                            <StackPanel>
                                <controls:VolumeControl DominantColorHex="{Binding DataContext.CurrentTrackForegroundColorHex, ElementName=RootWindow,  Converter={StaticResource HexToBrushConverter}}"  
                                                        Orientation="Horizontal"
                                                        Width="120"
                                                        ShowMuteButton="True"
                                                        Height="32"
                                                        />
                            </StackPanel>
                        </Border>
                    </Border>
                </Popup>
            </Grid>
        </Border>

        <controls:WaveformPlayerControl
                    x:Name="TrayWaveForm"
                    Grid.Row="1"
                    Grid.ColumnSpan="3"
                    UsePlaceholderWaveform="True"
                    DominantColorHex="{Binding CurrentTrackForegroundColorHex}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Stretch"
                    Height="8"
                    />
    </Grid>
</Window>


