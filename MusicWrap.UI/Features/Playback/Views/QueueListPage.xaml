<UserControl x:Class="MusicWrap.UI.Features.Playback.Views.QueueListPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MusicWrap.UI.Features.Playback.Views"
             xmlns:ex="clr-namespace:MusicWrap.UI.Helpers"
             xmlns:controls="clr-namespace:MusicWrap.UI.Controls"
             xmlns:controlsM="clr-namespace:MusicWrap.UI.Controls.Models"
             xmlns:vm="clr-namespace:MusicWrap.UI.Features.Playback.ViewModels"
             mc:Ignorable="d"
             x:Name="QueueRoot"
             Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Window}}"
             d:DataContext="{d:DesignInstance Type=vm:QueueViewModel}"
             d:DesignHeight="700" d:DesignWidth="500">

    <UserControl.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource DefaultButton}" x:Key="queueButtonStyle">
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Window}}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <ContextMenu x:Key="QueueTracksContextMenu">
            <MenuItem Header="Play now" Icon="{ex:Icon Glyph=E768}" Command="{Binding PlayTracksCommand}"/>
            <MenuItem Header="Play next" Icon="{ex:Icon Glyph=E893}" Command="{Binding MoveToNextCommand}"/>
            <Separator/>
            <controlsM:TrackToPlaylistMenu  TrackIds="{Binding SelectedTrackIds, Mode=OneWay}"/>
            <Separator/>
            <MenuItem Header="Remove from queue" Icon="{ex:Icon Glyph=E738}" Command="{Binding RemoveFromQueueCommand}"/>
        </ContextMenu>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Padding="0,4,0,8" BorderThickness="0,0,0,1" BorderBrush="{StaticResource StrokeSurface}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <controls:AppButton
                    Style="{StaticResource queueButtonStyle}" 
                    Command="{Binding SaveAsPlaylistCommand}"
                    Icon="&#xE74E;"
                    Text="Save as playlist"
                    />
                <controls:AppButton
                    Margin="8,0" 
                    Style="{StaticResource queueButtonStyle}" 
                    Command="{Binding ClearQueueCommand}"
                    Icon="&#xEA99;"
                    Text="Clear"
                    />
            </StackPanel>
        </Border>
        <controlsM:TracksView
            x:Name="QueueTracksView"
            Grid.Row="1"
            ItemsSource="{Binding QueueTrackRows}"
            SelectedTrackIds="{Binding SelectedTrackIds, Mode=TwoWay}"
            ContextMenu="{StaticResource QueueTracksContextMenu}"
            VisualMode="WithCoverArt"
            IndexMode="None"
            SelectionMode="Extended"
            IsMouseWheelScrollEnabled="True"
            AutoScrollToCurrentTrack="True"
            IsReorderEnabled="True"
            ReorderRequestedCommand="{Binding ReorderTrackCommand}"
            TrackActivatedCommand="{Binding ActivateTrackCommand}"
            RemoveRequestedCommand="{Binding RemoveSelectedTracksFromQueueCommand}"/>
    </Grid>
</UserControl>



