<UserControl x:Class="MusicWrap.UI.Features.Library.Components.AlbumPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MusicWrap.UI.Features.Library.Components"
             xmlns:ex="clr-namespace:MusicWrap.UI.Helpers"
             xmlns:vm="clr-namespace:MusicWrap.UI.Features.Library.ViewModels"
             xmlns:controlsM="clr-namespace:MusicWrap.UI.Controls.Models"
             xmlns:converters="clr-namespace:MusicWrap.UI.Converters"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:LibraryViewModel+AlbumData}"
             d:DesignHeight="200" d:DesignWidth="200"
             Width="180"
             Cursor="Hand">
    <UserControl.Resources>
        <converters:PathToImageConverter x:Key="PathToImageConverter"/>
    </UserControl.Resources>
    <!-- Renders an album -->
    <Border Background="Transparent" 
            ToolTip="{Binding Title}"
            BorderThickness="0"
            CornerRadius="4"
            Margin="4"
            Padding="0"
            >
        <Border.ContextMenu>
            <ContextMenu Placement="Right" Opened="AlbumContextMenu_Opened" MinWidth="175">
                <MenuItem Header="Play album now" Click="PlayAlbum" Icon="{ex:Icon Glyph=E768}"/>
                <MenuItem Header="Play album next" Click="AddAlbumToNext" Icon="{ex:Icon Glyph=E893}"/>
                <Separator/>
                <MenuItem Header="Add to queue" Click="AddToQueue" Icon="{ex:Icon Glyph=E710}"/>
                <controlsM:TrackToPlaylistMenu x:Name="AlbumTrackToPlaylistMenu"/>
                <Separator/>
                <MenuItem Header="Edit album" Icon="{ex:Icon Glyph=E70F}" Click="EditTracks_Click"/>
            </ContextMenu>
        </Border.ContextMenu>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Album Cover -->
            <Border Grid.Row="0" 
                    Background="Transparent"
                    Height="{Binding RelativeSource={RelativeSource Self}, Path=ActualWidth}"
                    VerticalAlignment="Top">
                <Image
                    Source="{Binding CoverImage}"
                    Stretch="UniformToFill"/>
            </Border>

            <!-- Album Info -->
            <Border Grid.Row="1" 
                    Padding="8,4"
                    Background="Transparent">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="{Binding Title}" 
                               FontSize="12" 
                               FontWeight="SemiBold"
                               Foreground="White"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap"/>
                    <TextBlock Grid.Row="1"
                               FontSize="11" 
                               TextAlignment="Center"
                               Foreground="#999999"
                               Text="{Binding Year}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>



