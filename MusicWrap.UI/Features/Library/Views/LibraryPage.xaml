<UserControl x:Class="MusicWrap.UI.Features.Library.Views.LibraryPage"
         x:Name="RootLibraryPage"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
         xmlns:local="clr-namespace:MusicWrap.UI.Features.Library.Components"
         xmlns:ex="clr-namespace:MusicWrap.UI.Helpers"
         xmlns:converters="clr-namespace:MusicWrap.UI.Converters"
         xmlns:vm="clr-namespace:MusicWrap.UI.Features.Library.ViewModels"
         xmlns:pages="clr-namespace:MusicWrap.UI.Features.Playback.Views"
         xmlns:controlsM="clr-namespace:MusicWrap.UI.Controls.Models"
         xmlns:selectors="clr-namespace:MusicWrap.UI.Selectors"
         xmlns:views="clr-namespace:MusicWrap.UI.Features.Library.Views"
         mc:Ignorable="d" 
         Foreground="White"
         d:DataContext="{d:DesignInstance Type=vm:LibraryViewModel+AlbumGridRowModel}"
         d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <!-- Library entries list -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <Menu Grid.Row="0" VerticalAlignment="Center">
                <MenuItem Header="Library" Icon="{ex:Icon Glyph=E8F1}">
                    <MenuItem Header="Rescan directories" Icon="{ex:Icon Glyph=E895}" Command="{Binding RescanAllDirectoriesCommand}"/>
                    <Separator/>
                    <MenuItem Header="Add Folder" Icon="{ex:Icon Glyph=E8F4}" Command="{Binding AddFolderCommand}"/>
                    <MenuItem Header="Add Files" Icon="{ex:Icon Glyph=E710}" Command="{Binding AddFilesCommand}"/>
                    <Separator/>
                    <MenuItem Header="Refresh library" Icon="{ex:Icon Glyph=E72C}" Command="{Binding RefreshCommand}"/>
                </MenuItem>
                <MenuItem Header="View" Icon="{ex:Icon Glyph=E7B3}">
                    <MenuItem Header="Albums" 
                              Command="{Binding SetViewModeCommand}" 
                              CommandParameter="Album"
                              IsCheckable="True" 
                              IsChecked="{Binding IsAlbumView, Mode=OneWay}"
                              Icon="{ex:Icon Glyph=E93C}"
                              />

                    <MenuItem Header="Artist" 
                              Command="{Binding SetViewModeCommand}" 
                              CommandParameter="Artist"
                              IsCheckable="True" 
                              IsChecked="{Binding IsArtistView, Mode=OneWay}"
                              Icon="{ex:Icon Glyph=E77B}"
                              />

                    <MenuItem Header="Genre" 
                              Command="{Binding SetViewModeCommand}" 
                              CommandParameter="Genre"
                              IsCheckable="True" 
                              IsChecked="{Binding IsGenreView, Mode=OneWay}"
                              Icon="{ex:Icon Glyph=E8D6}"
                              />

                    <MenuItem Header="Decade" 
                              Command="{Binding SetViewModeCommand}" 
                              CommandParameter="Decade"
                              IsCheckable="True" 
                              IsChecked="{Binding IsDecadeView, Mode=OneWay}"
                              Icon="{ex:Icon Glyph=E787}"
                              />

                    <Separator/>
                    <MenuItem Header="Ascending" 
                              Command="{Binding SetAscendingCommand}"
                              IsCheckable="True" 
                              IsChecked="{Binding Ascending, Mode=OneWay}"
                              Icon="{ex:Icon Glyph=E74A, FontSize=12}"
                              />

                    <MenuItem Header="Descending" 
                              Command="{Binding SetDescendingCommand}"
                              IsCheckable="True" 
                              IsChecked="{Binding Ascending, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                              Icon="{ex:Icon Glyph=E74B, FontSize=12}"
                              />
                </MenuItem>
            </Menu>
            <ListView
                    x:Name="EntriesListView"
                    ItemsSource="{Binding EntriesViewSource.View}"
                    SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                    Grid.Row="1"
                    SelectionMode="Single"
                    HorizontalAlignment="Stretch"
                    PreviewKeyDown="EntriesListView_PreviewKeyDown"
                    VirtualizingPanel.IsVirtualizing="True"
                    VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                    VirtualizingPanel.VirtualizationMode="Recycling"
                    VirtualizingPanel.ScrollUnit="Item"
                    VirtualizingPanel.CacheLength="2,2"
                    VirtualizingPanel.CacheLengthUnit="Page"
                    ScrollViewer.CanContentScroll="True"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    >
                <ListView.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <Border Background="Transparent" 
                                        Padding="8,4" 
                                        BorderThickness="0,0,0,1"
                                        BorderBrush="{StaticResource StrokeDivider}"
                                        Margin="0,8,0,0">
                                    <TextBlock Text="{Binding Name}" 
                                               FontSize="14" 
                                               FontWeight="SemiBold" 
                                               Foreground="White"/>
                                </Border>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="{x:Type GroupItem}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type GroupItem}">
                                            <StackPanel>
                                                <ContentPresenter />
                                                <ItemsPresenter />
                                            </StackPanel>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GroupStyle.ContainerStyle>
                    </GroupStyle>
                </ListView.GroupStyle>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Height" Value="auto"/>
                        <Setter Property="Padding" Value="4"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate DataType="LibraryEntry">
                        <Grid 
                            Margin="0"
                            ToolTipService.ToolTip="{Binding Title}"
                            HorizontalAlignment="Stretch">
                            <Grid.ContextMenu>
                                <ContextMenu Opened="LibraryContextMenu_Opened" MinWidth="175">
                                    <MenuItem Header="Play" Icon="{ex:Icon Glyph=E768}"/>
                                    <MenuItem Header="Play next" Icon="{ex:Icon Glyph=E893}"/>
                                    <Separator/>
                                    <MenuItem Header="Add to queue" Icon="{ex:Icon Glyph=E710}"/>
                                    <controlsM:TrackToPlaylistMenu x:Name="LibraryTrackToPlaylistMenu"/>
                                </ContextMenu>
                            </Grid.ContextMenu>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image
                                Grid.Column="0"
                                Source="{Binding ImagePath, Converter={StaticResource PathToImageConverter}, ConverterParameter=42}"
                                Width="42"
                                Height="42"
                                Stretch="UniformToFill"
                                RenderOptions.BitmapScalingMode="LowQuality"
                                />
                            <Grid Grid.Column="2">
                                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                                    <TextBlock Text="{Binding Title}" 
                                           FontSize="12" 
                                           FontWeight="Normal"
                                           TextTrimming="CharacterEllipsis"
                                           />
                                    <TextBlock Text="{Binding Description}" 
                                           FontSize="12" 
                                           Opacity="0.7"
                                           TextTrimming="CharacterEllipsis"
                                           />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
        <!-- Selected content -->
        <Grid Grid.Column="1" Background="{StaticResource BackgroundSmoke}">
            <views:LibraryEntryDetailPanel
                SelectedEntry="{Binding DataContext.SelectedEntry, Mode=OneWay, ElementName=RootLibraryPage}"
                />
        </Grid>
    </Grid>
</UserControl>



