<UserControl x:Class="MusicWrap.UI.Features.Library.Views.LibraryEntryDetailPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MusicWrap.UI.Features.Library.Views"
             xmlns:viewmodel="clr-namespace:MusicWrap.UI.Features.Library.ViewModels"
             xmlns:ex="clr-namespace:MusicWrap.UI.Helpers"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=viewmodel:LibraryEntryDetailPanelViewModel}"
             d:DesignHeight="800" d:DesignWidth="500">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="120"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="42" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Grid.Column="1" VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0"  Text="{Binding HeaderTitle}" FontSize="16" FontWeight="Bold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                    <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Opacity="0.75" FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center">
                            <Run Text="{Binding HeaderAlbumsCountText}"/>
                            <Run Text=" Albums"/>
                            <Run Text=" • "/>
                            <Run Text="{Binding HeaderTracksCountText}"/>
                            <Run Text=" tracks"/>
                            <Run Text=" • "/>
                            <Run Text="{Binding HeaderTotalDurationText}"/>
                        </TextBlock>
                        <Button Style="{StaticResource SubtleButton}" Margin="8,0,0,0" Padding="0"  Width="26" Height="26" ToolTip="Play all" Command="{Binding PlayAllTracksCommand}">
                            <TextBlock FontFamily="{StaticResource SymbolThemeFontFamily}" Text="&#xE768;"/>
                        </Button>
                        <Button Style="{StaticResource SubtleButton}" Padding="0" Width="26" Height="26" ToolTip="Shuffle" Command="{Binding ShuffleAllTracksCommand}">
                            <TextBlock FontFamily="{StaticResource SymbolThemeFontFamily}" Text="&#xE8B1;"/>
                        </Button>
                        <Button Style="{StaticResource SubtleButton}" Padding="0" Width="26" Height="26" ToolTip="Shuffle">
                            <TextBlock FontFamily="{StaticResource SymbolThemeFontFamily}" Text="&#xE712;"/>
                        </Button>
                    </StackPanel>

                </Grid>

                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Background="{StaticResource BackgroundLayer}" Padding="100,0,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>

                        <ListBox Grid.Column="0"
                                 ItemsSource="{Binding Tabs}"
                                 SelectedItem="{Binding SelectedTab, Mode=TwoWay}"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Bottom"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 SelectionMode="Single"
                                 HorizontalContentAlignment="Stretch">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="8,6"/>
                                    <Setter Property="Margin" Value="2,0"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="TabBorder"
                                                        Padding="{TemplateBinding Padding}"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="2,2,0,0">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="TabBorder" Property="Background" Value="#0fFFFFFF"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="TabBorder" Property="Background" Value="#2EFFFFFF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Title}" FontSize="12"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Menu Grid.Column="1" VerticalAlignment="Center" 
                              Background="Transparent" 
                              Margin="0" Padding="0">
                            <MenuItem 
                                Icon="{ex:Icon Glyph=E8CB, FontSize=14}"
                                Margin="0" Padding="0"
                                      >
                                <MenuItem Header="Year"
                                          IsCheckable="True"
                                          IsChecked="{Binding IsSortByYear, Mode=OneWay}"
                                          Command="{Binding SortTracksByYearCommand}"/>
                                <MenuItem Header="Title"
                                          IsCheckable="True"
                                          IsChecked="{Binding IsSortByTitle, Mode=OneWay}"
                                          Command="{Binding SortTracksByTitleCommand}"/>
                                <MenuItem Header="Duration"
                                          IsCheckable="True"
                                          IsChecked="{Binding IsSortByDuration, Mode=OneWay}"
                                          Command="{Binding SortTracksByDurationCommand}"/>
                                <MenuItem Header="Artist"
                                          IsCheckable="True"
                                          IsChecked="{Binding IsSortByArtistName, Mode=OneWay}"
                                          Command="{Binding SortTracksByArtistNameCommand}"/>
                                <Separator/>
                                <MenuItem Header="Ascending"
                                          IsCheckable="True"
                                          IsChecked="{Binding IsSortAscending, Mode=OneWay}"
                                          Command="{Binding SetSortAscendingCommand}"/>
                                <MenuItem Header="Descending"
                                          IsCheckable="True"
                                          IsChecked="{Binding IsSortDescending, Mode=OneWay}"
                                          Command="{Binding SetSortDescendingCommand}"/>
                            </MenuItem>
                        </Menu>
                    </Grid>
                </Border>

                <Border Width="90" Height="90" Grid.RowSpan="2" CornerRadius="45" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="8">
                    <Border.Background>
                        <ImageBrush ImageSource="{Binding HeaderImagePath, Converter={StaticResource PathToImageConverter}, ConverterParameter=medium:90}" Stretch="UniformToFill"/>
                    </Border.Background>
                </Border>
            </Grid>
        </Border>
        <Grid Grid.Row="1">
            <local:LibraryEntryAlbumsView
                LibraryViewModel="{Binding LibraryViewModel, RelativeSource={RelativeSource AncestorType={x:Type local:LibraryEntryDetailPanel}}}"
                Visibility="{Binding SelectedTab.Key, Converter={StaticResource TabStringToVisibilityConverter}, ConverterParameter=Albums}"/>
            <local:LibraryEntryTracksView 
                Visibility="{Binding SelectedTab.Key, Converter={StaticResource TabStringToVisibilityConverter}, ConverterParameter=Tracks}"/>

            <StackPanel 
                Visibility="{Binding SelectedTab.Key, Converter={StaticResource TabStringToVisibilityConverter}, ConverterParameter=Stats}" Margin="10">
                <TextBlock Text="{Binding StatsLine1}" FontSize="12" Margin="0,0,0,6"/>
                <TextBlock Text="{Binding StatsLine2}" FontSize="12" Margin="0,0,0,6"/>
                <TextBlock Text="{Binding StatsLine3}" FontSize="12"/>
            </StackPanel>

            <TextBlock Text="Profile"
                       Margin="10"
                       FontSize="12"
                       Visibility="{Binding SelectedTab.Key, Converter={StaticResource TabStringToVisibilityConverter}, ConverterParameter=Profile}"/>

            <TextBlock Text="More"
                       Margin="10"
                       FontSize="12"
                       Visibility="{Binding SelectedTab.Key, Converter={StaticResource TabStringToVisibilityConverter}, ConverterParameter=More}"/>
        </Grid>
    </Grid>
</UserControl>
