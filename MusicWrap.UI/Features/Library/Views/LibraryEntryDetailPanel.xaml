<UserControl x:Class="MusicWrap.UI.Features.Library.Views.LibraryEntryDetailPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MusicWrap.UI.Features.Library.Views"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="500">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="120"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="0" Margin="0,0,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="40" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Grid.Column="1" VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"  Text="{Binding HeaderTitle}" FontSize="16" FontWeight="Bold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                    <Border Grid.Row="1">
                        <TextBlock Opacity="0.75" Margin="0,4,0,0" FontSize="12" TextTrimming="CharacterEllipsis">
                            <Run Text="{Binding HeaderAlbumsCountText}"/>
                            <Run Text=" Albums"/>
                            <Run Text=" • "/>
                            <Run Text="{Binding HeaderTracksCountText}"/>
                            <Run Text=" tracks"/>
                            <Run Text=" • "/>
                            <Run Text="{Binding HeaderTotalDurationText}"/>
                        </TextBlock>
                    </Border>
                </Grid>

                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Background="{StaticResource BackgroundLayer}" Padding="90,0,4,0">
                    <ListBox ItemsSource="{Binding Tabs}"
                             SelectedItem="{Binding SelectedTab, Mode=TwoWay}"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Bottom"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             BorderThickness="0"
                             Background="Transparent"
                             SelectionMode="Single"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="6"/>
                                <Setter Property="Margin" Value="2,0"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="TabBorder"
                                                    Padding="{TemplateBinding Padding}"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="2,2,0,0">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="TabBorder" Property="Background" Value="#0fFFFFFF"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="TabBorder" Property="Background" Value="#2EFFFFFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Title}" FontSize="12"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
                <Border Width="90" Height="90" Grid.RowSpan="2" CornerRadius="45" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="8">
                    <Border.Background>
                        <ImageBrush ImageSource="{Binding HeaderImagePath, Converter={StaticResource PathToImageConverter}, ConverterParameter=medium:90}" Stretch="UniformToFill"/>
                    </Border.Background>
                </Border>
            </Grid>
        </Border>
        <Grid Grid.Row="1">
            <local:LibraryEntryAlbumsView
                LibraryViewModel="{Binding LibraryViewModel, RelativeSource={RelativeSource AncestorType={x:Type local:LibraryEntryDetailPanel}}}"
                Visibility="{Binding IsAlbumsTabActive, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <local:LibraryEntryTracksView Visibility="{Binding IsTracksTabActive, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <StackPanel Visibility="{Binding IsStatsTabActive, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="10">
                <TextBlock Text="{Binding StatsLine1}" FontSize="12" Margin="0,0,0,6"/>
                <TextBlock Text="{Binding StatsLine2}" FontSize="12" Margin="0,0,0,6"/>
                <TextBlock Text="{Binding StatsLine3}" FontSize="12"/>
            </StackPanel>

            <TextBlock Text="Profile"
                       Margin="10"
                       FontSize="12"
                       Visibility="{Binding IsProfileTabActive, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <TextBlock Text="More"
                       Margin="10"
                       FontSize="12"
                       Visibility="{Binding IsMoreTabActive, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </Grid>
    </Grid>
</UserControl>
