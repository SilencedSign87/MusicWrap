<UserControl x:Class="MusicWrap.UI.Features.Library.Views.AlbumTracksPage"
         x:Name="RootAlbumTracksPage"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
         xmlns:local="clr-namespace:MusicWrap.UI.Features.Library.Views"
         xmlns:vm="clr-namespace:MusicWrap.UI.Features.Library.ViewModels"
         xmlns:uimodels="clr-namespace:MusicWrap.UI.Controls.Models"
         xmlns:helpers="clr-namespace:MusicWrap.UI.Helpers"
         xmlns:converters="clr-namespace:MusicWrap.UI.Converters"
         mc:Ignorable="d" 
         d:DataContext="{d:DesignInstance Type=vm:AlbumTracksViewModel}"
         d:DesignHeight="450" d:DesignWidth="800"
         Foreground="{Binding ForegroundColor, Converter={StaticResource HexToBrushConverter}}"
         Background="Transparent">
    <UserControl.Resources>
        <converters:ItemCountToColumnsConverter x:Key="ItemCountToColumnsConverter"/>
        <ContextMenu x:Key="AlbumTracksContextMenu"
                 Opened="AlbumTracksContextMenu_Opened"
                     DataContext="{Binding Source={x:Reference RootAlbumTracksPage}, Path=DataContext}">
            <MenuItem Header="Play" Icon="{helpers:Icon Glyph=E768}" Command="{Binding PlayNowSelectedTracksCommand}"/>
            <Separator/>
            <MenuItem Header="Play next" Icon="{helpers:Icon Glyph=E893}" Command="{Binding PlayNextSelectedTracksCommand}"/>
            <MenuItem Header="Add to queue" Icon="{helpers:Icon Glyph=E710}" Command="{Binding AddSelectedTracksToQueueCommand}"/>
            <uimodels:TrackToPlaylistMenu x:Name="AlbumTracksTrackToPlaylistMenu"
                                          TrackIds="{Binding SelectedTrackIds, Mode=OneWay}"/>
            <Separator/>
            <MenuItem Header="Edit" Icon="{helpers:Icon Glyph=E70F}" Click="EditMenuItem_Click"/>
            <MenuItem Header="Remove" Icon="{helpers:Icon Glyph=E738}" IsEnabled="False"/>
            <MenuItem Header="Show in file explorer" Icon="{helpers:Icon Glyph=EC50}" Click="ShowInFileExplorerMenuItem_Click"/>
        </ContextMenu>
    </UserControl.Resources>
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Album Header -->
        <StackPanel Grid.Row="0" Margin="8,8,0,0">
            <StackPanel Margin="0,0,24,0">
                <TextBlock Text="{Binding AlbumTitle}" 
                           FontSize="16" 
                           FontWeight="Bold"
                           Foreground="{Binding ForegroundColor, Converter={StaticResource HexToBrushConverter}}"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock FontSize="12" 
                           VerticalAlignment="Center"
                       Foreground="{Binding ForegroundColor, Converter={StaticResource HexToBrushConverter}}"
                       Opacity="0.7">
                    <Run Text="{Binding AlbumArtists}"/>
                    <Run Text=" • "/>
                    <Run Text="{Binding AlbumYear}"/>
                </TextBlock>
                <Button Width="26" Height="26" Padding="0" VerticalAlignment="Top"
                        Foreground="{Binding ForegroundColor, Converter={StaticResource HexToBrushConverter}}"
                        Background="Transparent"
                        BorderThickness="0"
                        Margin="8,0,0,0"
                        ToolTip="{Binding AlbumPlayTooltip}" 
                        Click="PlayPauseAlbum_Click"
                        >
                    <TextBlock FontFamily="{StaticResource SymbolThemeFontFamily}" Text="{Binding AlbumPlayGlyph}"/>
                </Button>
                <Button
                        Width="26" Height="26" Padding="0" VerticalAlignment="Top"
                        Foreground="{Binding ForegroundColor, Converter={StaticResource HexToBrushConverter}}"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="ShuffleButton_Click"
                    >
                    <TextBlock FontFamily="{StaticResource SymbolThemeFontFamily}" Text="&#xE8B1;"/>
                </Button>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="1" x:Name="AlbumTracksTracksHost">
            <uimodels:TracksView ItemsSource="{Binding Tracks}"
                                 AllTrackIds="{Binding AllTrackIds}"
                                 SelectedTrackIds="{Binding SelectedTrackIds, Mode=TwoWay}"
                                 GroupByDisk="True"
                                 UseColumnFlowPanel="True"
                                 ContextMenu="{StaticResource AlbumTracksContextMenu}"
                                 VisualMode="CompactNoCover"
                                 IndexMode="TrackNumber"
                                 SelectionMode="Extended">
                <uimodels:TracksView.ColumnFlowColumns>
                    <MultiBinding Converter="{StaticResource ItemCountToColumnsConverter}" ConverterParameter="10,600">
                        <Binding Path="Tracks.Count"/>
                        <Binding ElementName="AlbumTracksTracksHost" Path="ActualWidth"/>
                    </MultiBinding>
                </uimodels:TracksView.ColumnFlowColumns>
            </uimodels:TracksView>
        </Grid>
    </Grid>
</UserControl>



