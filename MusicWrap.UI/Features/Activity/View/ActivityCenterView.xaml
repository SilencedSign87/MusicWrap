<UserControl x:Class="MusicWrap.UI.Features.Activity.View.ActivityCenterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MusicWrap.UI.Features.Activity.View"
             xmlns:models="clr-namespace:MusicWrap.UI.Features.Activity.Models"
             xmlns:vm="clr-namespace:MusicWrap.UI.Features.Activity.Viewmodel"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance vm:ActivityCenterViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="500" d:DesignWidth="250">
    <UserControl.Resources>
        <DataTemplate x:Key="ActivityCardTemplate" DataType="models:ActivityModel">
            <Border
                Background="{StaticResource BackgroundCard1}" 
                CornerRadius="6" Padding="8,6" Margin="0,0,0,4"
                BorderBrush="{StaticResource StrokeLayerCard}" BorderThickness="1"
                >
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" 
                               Text="{Binding Title}" 
                               FontWeight="SemiBold" FontSize="13"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextTrimming="CharacterEllipsis"/>
                    <Button Grid.Row="0" Grid.Column="1" 
                            Style="{StaticResource TransparentButton}"
                            Width="20" Height="20" Padding="0"
                            Visibility="{Binding ShowCancelButton, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Command="{Binding DataContext.CancelActivityCommand, 
                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            ToolTip="Cancel">
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="" FontSize="10"/>
                    </Button>
                    <TextBlock Grid.Row="1" Grid.ColumnSpan="2"
                               Text="{Binding Description}"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,2,0,4"/>

                    <ProgressBar Grid.Row="2" Grid.ColumnSpan="2" 
                                 Height="6" 
                                 Minimum="0" Maximum="1"
                                 Value="{Binding Progress}"
                                 IsIndeterminate="{Binding IsIndeterminate}"
                                 Visibility="{Binding Status, Converter={x:Null}}"
                                 Foreground="{StaticResource AccentBrush100}"
                                 Background="{StaticResource BackgroundControlDefault}"
                                 BorderThickness="0"
                                 >
                        <ProgressBar.ToolTip>
                            <TextBlock>
                                <Run Text="{Binding Progress, StringFormat={}{0:P0}}"/>
                                <Run Text=" complete"/>
                            </TextBlock>
                        </ProgressBar.ToolTip>
                    </ProgressBar>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,8" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" FontSize="14" Text="Activity Center" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Style="{StaticResource TransparentButton}" Width="26" Height="26" Padding="0" ToolTip="Clear done" Command="{Binding ClearDoneCommand }">
                <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xEA99;"/>
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Activities}"
                          ItemTemplate="{StaticResource ActivityCardTemplate}"
                          HorizontalContentAlignment="Stretch">
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
            </ItemsControl>
        </ScrollViewer>

        <TextBlock Grid.Row="1" 
                   Text="There are no ongoing activities"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="{Binding Activities.Count, Converter={StaticResource ItemCountToVisibilityConverter}, ConverterParameter=Invert}"/>
    </Grid>
</UserControl>
