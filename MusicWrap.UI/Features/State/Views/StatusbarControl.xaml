<UserControl x:Class="MusicWrap.UI.Features.State.StatusbarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MusicWrap.UI.Features.State"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             BorderThickness="0,1,0,0"
             BorderBrush="{StaticResource StrokeSurface}"
             >
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition  Width="Auto"/>
            <ColumnDefinition  Width="*"/>
            <ColumnDefinition  Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="4"/>
        </Grid.RowDefinitions>
        
        <StackPanel x:Name="LeftPanel" Grid.Column="0" Grid.Row="0"  Orientation="Horizontal" HorizontalAlignment="Left" Margin="4,0,2,0">
            <TextBlock Text="now playing" VerticalAlignment="Center"/>
        </StackPanel>
        <StackPanel x:Name="CenterPanel" Grid.Column="0" Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="2,0">

        </StackPanel>
        <StackPanel x:Name="RightPanel" Grid.Column="0" Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="2,0,4,0">

        </StackPanel>
        <ProgressBar 
            Grid.Column="0" 
            Grid.Row="1"
            Grid.ColumnSpan="3" 
            VerticalAlignment="Bottom"
            Minimum="0"
            Maximum="100"
            Foreground="{StaticResource AccentBrush80}" 
            Background="Transparent" 
            IsIndeterminate="True"
                     />
    </Grid>
</UserControl>
