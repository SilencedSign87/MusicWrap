<UserControl x:Class="MusicWrap.UI.Features.Settings.Views.SettingsDirectoriesManagerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MusicWrap.UI.Features.Settings.Views"
      xmlns:data="clr-namespace:MusicWrap.Data.Library;assembly=MusicWrap.Data"
      xmlns:vm="clr-namespace:MusicWrap.UI.Features.Settings.ViewModels"
      xmlns:controls="clr-namespace:MusicWrap.UI.Controls"
      xmlns:converters="clr-namespace:MusicWrap.UI.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="800"
      d:DataContext="{d:DesignInstance Type=vm:DirectoriesManagerViewModel}"
      Foreground="White">
    <UserControl.Resources>
        <converters:DateTimeToDisplayConverter x:Key="DateTimeToDisplayConverter" />
    </UserControl.Resources>
    <StackPanel Margin="16">
        <controls:SectionTitleSeparator Title="Directories" IconGlyph="&#xE8B7;" Margin="0,0,0,12"/>
        <Grid MaxHeight="400">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <!-- List of directories -->
            <Grid Grid.Row="0">
                <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Auto">
                    <ListView 
                    ItemsSource="{Binding Directories}" 
                    Background="#1e1e1e"
                    SelectionMode="Multiple"
                    BorderThickness="0"
                    Padding="8"
                    SelectionChanged="ListView_SelectionChanged"
                    HorizontalContentAlignment="Stretch">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Height" Value="Auto"/>
                                <Setter Property="Padding" Value="12,8"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate DataType="data:ScanDirectory">
                                <Grid HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition Width="auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Path, Mode=OneWay}" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding LastScan, Mode=OneWay, Converter={StaticResource DateTimeToDisplayConverter}}" FontSize="12" Opacity="0.7"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <Button Style="{StaticResource SubtleButton}" Padding="8"
                                        Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                        CommandParameter="{Binding Path}">
                                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xec50;" FontSize="20"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </ScrollViewer>
            </Grid>
            <!-- Progress -->
            <Grid Grid.Row="1" Visibility="{Binding IsScanning}">
                <StackPanel Margin="8">
                    <ProgressBar 
                    Height="4" 
                    Margin="8,0" 
                    Foreground="{StaticResource AccentBrush80}" 
                    Background="#111111" 
                    BorderThickness="0"
                    Minimum="0"
                    Maximum="100"
                    Value="{Binding ProgressPercentage, Mode=OneWay}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="8,4,8,0">
                        <TextBlock Text="{Binding FilesProcessed, StringFormat='{}{0}'}" FontSize="12" Opacity="0.9"/>
                        <TextBlock Text="/" FontSize="12" Opacity="0.7" Margin="2,0"/>
                        <TextBlock Text="{Binding TotalFiles, StringFormat='{}{0}'}" FontSize="12" Opacity="0.9"/>
                        <TextBlock Text="files" FontSize="12" Opacity="0.7" Margin="4,0,0,0"/>
                        <TextBlock Text="•" FontSize="12" Opacity="0.5" Margin="8,0"/>
                        <TextBlock Text="{Binding CurrentFile}" FontSize="12" Opacity="0.7" TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                    </StackPanel>
                    <Button Style="{StaticResource DefaultButton}" Width="100" HorizontalAlignment="Left" Margin="0,4,0,0" Command="{Binding CancelScanCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe Fluent Icons" FontSize="18" Text="&#xe711;"/>
                            <TextBlock Text="Cancel" FontSize="14" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
            <!-- Actions -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="8">
                <Button Style="{StaticResource AccentButton}" Command="{Binding AddFolderCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe Fluent Icons" FontSize="18" Text="&#xe8f4;"/>
                        <TextBlock Text="Add" FontSize="14" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource DefaultButton}" Margin="8,0,0,0" Command="{Binding ScanSelectedCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe Fluent Icons" FontSize="18" Text="&#xedab;"/>
                        <TextBlock FontSize="14" Margin="8,0,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Scan All"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSelectedDirectories}" Value="True">
                                            <Setter Property="Text" Value="Scan Selected"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource DefaultButton}" Margin="8,0,0,0" Command="{Binding RemoveSelectedCommand}" IsEnabled="{Binding HasSelectedDirectories}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe Fluent Icons" FontSize="18" Text="&#xe74d;"/>
                        <TextBlock Text="Delete" FontSize="14" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
        <controls:SectionTitleSeparator Title="Library Management" IconGlyph="&#xE8F1;" Margin="0,0,0,12"/>
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Rebuild library" FontSize="14" FontWeight="SemiBold"/>
                <TextBlock Text="Rebuild the library database." FontSize="12" Opacity="0.8" TextWrapping="Wrap"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Margin="8,0">
                <Button Content="Rebuild library" Style="{StaticResource DefaultButton}"/>
            </StackPanel>
        </Grid>
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Rebuild cache" FontSize="14" FontWeight="SemiBold"/>
                <TextBlock Text="If your library is out of sync, you can rebuild the cache to update it" FontSize="12" Opacity="0.8" TextWrapping="Wrap"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Margin="8,0">
                <Button Content="Rebuild cache" Style="{StaticResource DefaultButton}"/>
            </StackPanel>
        </Grid>
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Clear playlists" FontSize="14" FontWeight="SemiBold"/>
                <TextBlock Text="Delete all playlists" FontSize="12" Opacity="0.8" TextWrapping="Wrap"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Margin="8,0">
                <Button Content="Delete playlists" Style="{StaticResource DefaultButton}"/>
            </StackPanel>
        </Grid>
        <controls:SectionTitleSeparator Title="Library integrity" IconGlyph="&#xE7FB;" Margin="0,0,0,12"/>
        <Grid Margin="0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Verify library files" FontSize="14" FontWeight="SemiBold"/>
                <TextBlock Text="Check for missing, moved, or duplicate tracks and orphaned covers"
                   FontSize="12" Opacity="0.8" TextWrapping="Wrap"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Margin="8,0" VerticalAlignment="Center">
                <Button Content="Run Integrity Check"
                Style="{StaticResource DefaultButton}"
                Command="{Binding RunIntegrityCheckCommand}"/>
            </StackPanel>
        </Grid>
    </StackPanel>
</UserControl>


