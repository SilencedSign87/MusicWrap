<UserControl x:Class="MusicWrap.UI.Features.Providers.Views.ServicesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MusicWrap.UI.Features.Providers.Views"
             xmlns:controls="clr-namespace:MusicWrap.UI.Controls"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="900">
    <Grid x:Name="RootGrid">
        <StackPanel x:Name="ServiceHomeView" Margin="16">
            <UniformGrid x:Name="ServicesUniformGrid" Columns="3" Rows="1">
                <Button VerticalAlignment="Center" HorizontalAlignment="Center" Width="120" Height="120" Click="HandleGoToYoutubeProvider">
                    <StackPanel>
                        <Image Source="/Resources/Icons/Youtube_Music_icon.png" Width="42" Height="42" />
                        <TextBlock Text="YouTube Music" HorizontalAlignment="Center" Margin="0,5,0,0" />
                    </StackPanel>
                </Button>
            </UniformGrid>
        </StackPanel>
        <ContentControl x:Name="ContentControlRenderer" Visibility="Hidden" />
    </Grid>
</UserControl>


