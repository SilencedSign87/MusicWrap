<UserControl x:Class="MusicWrap.UI.Features.Playlist.Views.PlaylistPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MusicWrap.UI.Features.Playlist.Views"
             xmlns:ex="clr-namespace:MusicWrap.UI.Helpers"
             xmlns:controlsM="clr-namespace:MusicWrap.UI.Controls.Models"
             xmlns:vm="clr-namespace:MusicWrap.UI.Features.Playlist.ViewModels"
             mc:Ignorable="d" 
             Foreground="White"
             d:DataContext="{d:DesignInstance Type=vm:PlaylistViewModel}"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="PlaylistCompactGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="RowHeight" Value="22"/>
            <Setter Property="ColumnHeaderHeight" Value="24"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
            <Setter Property="EnableColumnVirtualization" Value="True"/>
        </Style>

        <Style x:Key="PlaylistCompactRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BackgroundControlHover}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBrush100}"/>
                    <Setter Property="Foreground" Value="{StaticResource TextOnAccentPrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PlaylistCompactCell" TargetType="DataGridCell">
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="PlaylistCompactHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource StrokeDivider}"/>
        </Style>

        <ContextMenu x:Key="PlaylistTracksContextMenu" Opened="PlaylistTracksContextMenu_Opened">
            <MenuItem Header="Play now" Icon="{ex:Icon Glyph=E768}" Click="PlaylistPlayNow_Click"/>
            <Separator/>
            <MenuItem Header="Add next" Icon="{ex:Icon Glyph=E893}" Click="PlaylistPlayNext_Click"/>
            <MenuItem Header="Add to queue" Icon="{ex:Icon Glyph=E710}" Click="PlaylistAddToQueue_Click"/>
            <controlsM:TrackToPlaylistMenu x:Name="PlaylistTrackToPlaylistMenu"/>
            <Separator/>
            <MenuItem Header="Remove from playlist" Icon="{ex:Icon Glyph=E74D}" Click="PlaylistRemoveSelected_Click"/>
        </ContextMenu>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" MinWidth="200" MaxWidth="400" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Menu Grid.Row="0">
                <MenuItem Header="Playlists" Icon="{ex:Icon Glyph=EA37}">
                    <MenuItem Header="New playlist" Icon="{ex:Icon Glyph=E710}" Command="{Binding NewPlaylistCommand}" />
                    <MenuItem Header="Refresh" Icon="{ex:Icon Glyph=E72C}" Command="{Binding RefreshCommand}" />
                </MenuItem>
                <MenuItem Header="View" Icon="{ex:Icon Glyph=E890}">
                    <MenuItem Header="Title" IsCheckable="True" />
                    <MenuItem Header="Album" IsCheckable="True" />
                    <MenuItem Header="Artist" IsCheckable="True" />
                    <MenuItem Header="Date added" IsCheckable="True" />
                    <Separator />
                    <MenuItem Header="Ascending" 
                        IsCheckable="True" 
                        Icon="{ex:Icon Glyph=E74A, FontSize=12}"
                        />

                    <MenuItem Header="Descending" 
                        IsCheckable="True" 
                        Icon="{ex:Icon Glyph=E74B, FontSize=12}"
                        />
                    <Separator />
                    <MenuItem Header="Compact view" 
                              IsCheckable="True" 
                              IsChecked="{Binding CompactMode, Mode=TwoWay}"
                              Icon="{ex:Icon Glyph=E700}" />
                    <MenuItem Header="List View" 
                              IsCheckable="True" 
                              IsChecked="{Binding CompactMode, Converter={StaticResource InverseBoolConverter}}"
                              Icon="{ex:Icon Glyph=E8FD}" />
                </MenuItem>
            </Menu>

            <ListView
                ItemsSource="{Binding Entries}"
                SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                Grid.Row="1"
                SelectionMode="Single"
                HorizontalAlignment="Stretch"
                >
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Height" Value="auto"/>
                        <Setter Property="Padding" Value="4"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate DataType="vm:PlaylistEntry">
                        <Grid>
                            <!-- Compact -->
                            <StackPanel x:Name="CompactLayout"
                            Orientation="Horizontal"
                            Margin="0"
                            ToolTipService.ToolTip="{Binding Title}"
                            HorizontalAlignment="Stretch">
                                <Image Source="{Binding ImagePath, Converter={StaticResource PathToImageConverter}, ConverterParameter=42}"
                           Width="42"
                           Height="42"
                           Stretch="UniformToFill"
                           RenderOptions.BitmapScalingMode="LowQuality" />
                                <StackPanel Orientation="Vertical" Margin="8,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontSize="14" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Description}" FontSize="11" Opacity="0.7" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </StackPanel>

                            <!-- List -->
                            <StackPanel
                                x:Name="ListLayout"
                                Visibility="Collapsed"
                                Orientation="Horizontal"
                                >
                                <TextBlock FontFamily="{StaticResource SymbolThemeFontFamily}" Text="&#xE90B;" VerticalAlignment="Center" Margin="8,0"/>
                                <TextBlock
                                    TextTrimming="CharacterEllipsis"
                                    VerticalAlignment="Center"
                                    Text="{Binding Title}"
                                    FontSize="14"
                                    />
                                <TextBlock
                                    TextTrimming="CharacterEllipsis"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Margin="8,0"
                                    Opacity="0.6"
                                    >
                                    <Run Text="• " />
                                    <Run Text="{Binding Description}" />
                                </TextBlock>

                                <TextBlock 
                                    />
                            </StackPanel>
                        </Grid>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding DataContext.CompactMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="False">
                                <Setter TargetName="CompactLayout" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="ListLayout" Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListView.ItemTemplate>

            </ListView>

        </Grid>
        <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
        <Border Grid.Column="2" Background="{StaticResource BackgroundSmoke}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="120" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="40" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Grid.Column="1" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="{Binding SelectedEntry.Title}" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="1" Text="{Binding SelectedEntry.Description}" FontSize="12"/>
                    </Grid>
                    <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Background="{StaticResource BackgroundLayer}">
                        <ListBox
                            Margin="4,0"
                            ItemsSource="{Binding AllTabs}"
                            SelectedItem="{Binding SelectedTab, Mode=TwoWay}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            ScrollViewer.VerticalScrollBarVisibility="Disabled"
                            BorderThickness="0"
                            Background="Transparent"
                            SelectionMode="Single"
                            HorizontalContentAlignment="Stretch">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="8,6"/>
                                    <Setter Property="Margin" Value="2,0"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="TabBorder"
                                                    Padding="{TemplateBinding Padding}"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="2,2,0,0">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="TabBorder" Property="Background" Value="#0fFFFFFF"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="TabBorder" Property="Background" Value="#2EFFFFFF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="12"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <Border Grid.RowSpan="2"  Width="90" Height="90" CornerRadius="45" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="8">
                        <Border.Background>
                            <ImageBrush
                                ImageSource="{Binding SelectedEntry.ImagePath, Converter={StaticResource PathToImageConverter}, ConverterParameter=150}"
                                />
                        </Border.Background>
                    </Border>

                </Grid>
                <Grid
                    Grid.Row="1" 
                    >
                    <StackPanel Visibility="{Binding SelectedTab, Converter={StaticResource TabStringToVisibilityConverter}, ConverterParameter=Tracks}">
                        <controlsM:TracksView
                        ItemsSource="{Binding Tracks}"
                        AllTrackIds="{Binding AllTrackIds}"
                        SelectedTrackIds="{Binding SelectedTrackIds, Mode=TwoWay}"
                        ContextMenu="{StaticResource PlaylistTracksContextMenu}"
                        VisualMode="ListImage"
                        IndexMode="ListIndex"
                        SelectionMode="Extended"
                        IsReorderEnabled="True"
                        ReorderRequestedCommand="{Binding ReorderTrackCommand}"
                        RemoveRequestedCommand="{Binding RemoveSelectedTracksCommand}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>



