<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background -->
    <SolidColorBrush x:Key="BackgroundSolid" Color="#202020" />
    <SolidColorBrush x:Key="BackgroundSolidAlt" Color="#0a0a0a" />
    <SolidColorBrush x:Key="BackgroundSolid2" Color="#1c1c1c" />
    <SolidColorBrush x:Key="BackgroundSolid3" Color="#282828" />
    <SolidColorBrush x:Key="BackgroundSolid4" Color="#2c2c2c" />
    <SolidColorBrush x:Key="BackgroundSolid5" Color="#333333" />
    <SolidColorBrush x:Key="BackgroundSolid6" Color="#373737" />

    <!-- Layer -->
    <SolidColorBrush x:Key="BackgroundLayer" Color="#3a3a3a" Opacity="0.3"/>
    <SolidColorBrush x:Key="BackgroundLayerAlt" Color="#ffffff" Opacity="0.0538" />

    <!-- Card -->
    <SolidColorBrush x:Key="BackgroundCard1" Color="#ffffff" Opacity="0.0512"/> <!-- Default -->
    <SolidColorBrush x:Key="BackgroundCard2" Color="#ffffff" Opacity="0.0326"/> <!-- Hover -->
    <SolidColorBrush x:Key="BackgroundCard3" Color="#ffffff" Opacity="0.0698" /> <!-- Pressed -->

    <SolidColorBrush x:Key="BackgroundSmoke" Color="#000000" Opacity="0.3" />

    <!--Control-->
    <SolidColorBrush x:Key="BackgroundControlTransparent" Color="#FFFFFF" Opacity="0"/>
    <SolidColorBrush x:Key="BackgroundControlDefault" Color="#FFFFFF" Opacity="0.0605"/>
    <SolidColorBrush x:Key="BackgroundControlHover" Color="#FFFFFF" Opacity="0.0837" />
    <SolidColorBrush x:Key="BackgroundControlPressed" Color="#FFFFFF" Opacity="0.0326" />
    <SolidColorBrush x:Key="BackgroundControlDisable" Color="#FFFFFF" Opacity="0.0419" />
    
    <!-- Floating -->
    <SolidColorBrush x:Key="BackgroundFloating" Color="#2C2C2C" Opacity="0.96" />

    <!-- Stroke -->
    <SolidColorBrush x:Key="StrokeSurface" Color="#757575" Opacity="0.4"/>
    <SolidColorBrush x:Key="StrokeLayerCard" Color="#000000" Opacity="0.1"/>
    <SolidColorBrush x:Key="StrokeFloating" Color="#000000" Opacity="0.2"/>
    <SolidColorBrush x:Key="StrokeControl" Color="#ffffff" Opacity="0.0698"/>
    <SolidColorBrush x:Key="StrokeDivider" Color="#ffffff" Opacity="0.0837"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FFB0B0B0"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="#FF666666"/>
    
    <!-- Accent -->
    <SolidColorBrush x:Key="AccentBrush10" Color="#000307" />
    <SolidColorBrush x:Key="AccentBrush20" Color="#001929" />
    <SolidColorBrush x:Key="AccentBrush30" Color="#002840" />
    <SolidColorBrush x:Key="AccentBrush40" Color="#003454" />
    <SolidColorBrush x:Key="AccentBrush50" Color="#004169" />
    <SolidColorBrush x:Key="AccentBrush60" Color="#004D80" />
    <SolidColorBrush x:Key="AccentBrush70" Color="#005A99" />
    <SolidColorBrush x:Key="AccentBrush80" Color="#0067B4" />
    <SolidColorBrush x:Key="AccentBrush90" Color="#0074D1" />
    <SolidColorBrush x:Key="AccentBrush100" Color="#3881E1" />
    <SolidColorBrush x:Key="AccentBrush110" Color="#588DEE" />
    <SolidColorBrush x:Key="AccentBrush120" Color="#759AF9" />
    <SolidColorBrush x:Key="AccentBrush130" Color="#90A7FF" />
    <SolidColorBrush x:Key="AccentBrush140" Color="#ABB5FF" />
    <SolidColorBrush x:Key="AccentBrush150" Color="#C2C4FF" />
    <SolidColorBrush x:Key="AccentBrush160" Color="#D6D3FF" />
    
    

    <!--Text in accent-->
    <SolidColorBrush x:Key="TextOnAccentPrimaryBrush" Color="#000000"/>
    <SolidColorBrush x:Key="TextOnAccentSecondaryBrush" Color="#121212"/>
    <SolidColorBrush x:Key="TextOnAccentTertiaryBrush" Color="#202020"/>


</ResourceDictionary>