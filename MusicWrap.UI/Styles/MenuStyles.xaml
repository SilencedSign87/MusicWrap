<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Botón top-level (Sort) -->
    <Style x:Key="BaseMenuItem" TargetType="MenuItem">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="MinHeight" Value="0"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- Items dentro del desplegable -->
    <Style x:Key="SortPopupMenuItem" TargetType="MenuItem">
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="MinHeight" Value="0"/>
    </Style>

    <!-- Menu raíz: elimina separación del contenedor -->
    <Style x:Key="SortMenuStyle" TargetType="Menu">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- Template top-level sin padding interno arriba -->
    <ControlTemplate x:Key="TopLevelMenuItemNoGapTemplate" TargetType="MenuItem">
        <Border Background="{TemplateBinding Background}" Padding="0" Margin="0">
            <Grid>
                <ContentPresenter Margin="{TemplateBinding Padding}"
                                  ContentSource="Header"
                                  VerticalAlignment="Center"/>

                <Popup x:Name="PART_Popup"
                       Placement="Bottom"
                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                       AllowsTransparency="True"
                       Focusable="False">
                    <Border Padding="0" Margin="0"
                            Background="{DynamicResource BackgroundLayer}"
                            BorderBrush="{DynamicResource StrokeDivider}"
                            BorderThickness="1">
                        <StackPanel IsItemsHost="True" Margin="0"/>
                    </Border>
                </Popup>
            </Grid>
        </Border>
    </ControlTemplate>

</ResourceDictionary>