<UserControl x:Class="MusicWrap.UI.Pages.LibraryExplorerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MusicWrap.UI.Pages"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="72" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Background="{DynamicResource LayerFillColorDefaultBrush}" Orientation="Horizontal">
            <TextBox Grid.Column="1" Margin="16" Width="200" AutomationProperties.Name="Search library..." VerticalAlignment="Center"/>
        </StackPanel>
        <ListView Grid.Row="1">

        </ListView>
    </Grid>
</UserControl>
