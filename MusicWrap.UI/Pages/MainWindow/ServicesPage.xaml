<UserControl x:Class="MusicWrap.UI.Pages.MainWindow.ServicesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MusicWrap.UI.Pages.MainWindow"
              xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Padding="2" Background="{StaticResource BackgroundLayer}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button x:Name="AddToLibraryButton" Visibility="Hidden" Style="{StaticResource AccentButton}" Click="AddToLibraryButton_Click" Height="32">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe Fluent Icons"  Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Add to library"  VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button ToolTip="Reload" Click="Reload_click">
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE72C;" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        <wv2:WebView2 
            x:Name="YoutubeMusicWebView"
            Grid.Row="1" 
            Source="https://music.youtube.com/" 
            NavigationCompleted="YoutubeMusicWebView_NavigationCompleted"
            SourceChanged="YoutubeMusicWebView_SourceChanged"
                      />
    </Grid>
</UserControl>
