<UserControl x:Class="MusicWrap.UI.Pages.MainWindow.NowPlayingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MusicWrap.UI.Pages.MainWindow"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition  MinWidth="0" MaxWidth="300" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <GridSplitter
            Grid.Column="1"
            />
        <Border Grid.Column="2" Background="{StaticResource BackgroundSmoke}">

        </Border>

    </Grid>
</UserControl>
