<UserControl x:Class="MusicWrap.UI.Pages.MainWindow.AlbumTracksPage"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
         xmlns:local="clr-namespace:MusicWrap.UI.Pages.MainWindow"
         xmlns:vm="clr-namespace:MusicWrap.UI.ViewModels.Library"
         xmlns:ex="clr-namespace:MusicWrap.UI.Helpers"
         xmlns:converters="clr-namespace:MusicWrap.UI.Converters"
         mc:Ignorable="d" 
         d:DataContext="{d:DesignInstance Type=vm:AlbumTracksViewModel}"
         d:DesignHeight="450" d:DesignWidth="800"
         Foreground="{Binding ForegroundColor, Converter={StaticResource HexToBrushConverter}}"
         Background="Transparent">
    <UserControl.Resources>
        <converters:DiskNumberToVisibilityConverter x:Key="DiskNumberToVisibilityConverter"/>
        <converters:ItemCountToColumnsConverter x:Key="ItemCountToColumnsConverter"/>
    </UserControl.Resources>
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Album Header -->
        <StackPanel Grid.Row="0" Margin="0,8,0,8">
            <Grid Margin="0,0,24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Button Width="26" Height="26" Padding="0" VerticalAlignment="Top"
                        Grid.Column="0"
                        Foreground="{Binding ForegroundColor, Converter={StaticResource HexToBrushConverter}}"
                        Background="Transparent"
                        BorderThickness="0"
                        ToolTip="{Binding AlbumPlayTooltip}" 
                        Command="{Binding PlayPauseAlbumCommand}"
                        >
                    <TextBlock FontFamily="{StaticResource SymbolThemeFontFamily}" Text="&#xE768;"/>
                </Button>
                <TextBlock Text="{Binding AlbumTitle}" 
                           Grid.Column="1"
                           FontSize="16" 
                           FontWeight="Bold"
                           Foreground="{Binding ForegroundColor, Converter={StaticResource HexToBrushConverter}}"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>
            <TextBlock FontSize="12" 
                       Foreground="{Binding ForegroundColor, Converter={StaticResource HexToBrushConverter}}"
                       Opacity="0.7"
                       Margin="0,4,0,0">
                <Run Text="{Binding AlbumArtists}"/>
                <Run Text=" • "/>
                <Run Text="{Binding AlbumYear}"/>
            </TextBlock>
        </StackPanel>

        <!-- Tracks List Grouped by Disk -->
        <ItemsControl Grid.Row="1"
                      ItemsSource="{Binding DiskGroups}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="0,0,0,24">
                        <!-- Disk Header (only show if there are multiple disks) -->
                        <TextBlock Text="{Binding DiskTitle}" 
                                   FontSize="14" 
                                   FontWeight="SemiBold"
                                   Foreground="{Binding DataContext.ForegroundColor, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource HexToBrushConverter}}"
                                   Opacity="0.8"
                                   Margin="0,0,0,8"
                                   Visibility="{Binding DiskNumber, Converter={StaticResource DiskNumberToVisibilityConverter}}"/>

                        <!-- Tracks in this disk -->
                        <ItemsControl ItemsSource="{Binding Tracks}"
                                      Name="TracksItemsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ex:ColumnFlowPanel>
                                        <ex:ColumnFlowPanel.Columns>
                                            <MultiBinding Converter="{StaticResource ItemCountToColumnsConverter}" ConverterParameter="10,600">
                                                <Binding RelativeSource="{RelativeSource FindAncestor, AncestorType=ItemsControl}" Path="Items.Count"/>
                                                <Binding RelativeSource="{RelativeSource FindAncestor, AncestorType=ItemsControl}" Path="ActualWidth"/>
                                            </MultiBinding>
                                        </ex:ColumnFlowPanel.Columns>
                                    </ex:ColumnFlowPanel>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid
                                            Margin="0,4"
                                            MouseLeftButtonDown="StartPlayingFromTrack"
                                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Cursor="Hand"
                                        >
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#1f000000"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="False">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ContextMenu>
                                            <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}" Placement="Right">
                                                <MenuItem Header="Play Now" 
                                                          Command="{Binding PlayTrackCommand}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext.Id, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                                          Icon="{ex:Icon Glyph=E768}"
                                                          />

                                                <MenuItem Header="Play Next" 
                                                          Command="{Binding PlayNextCommand}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext.Id, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          Icon="{ex:Icon Glyph=ECC8}"
                                                          />

                                                <MenuItem Header="Add to Queue" 
                                                          Command="{Binding AddToQueueCommand}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext.Id, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          Icon="{ex:Icon Glyph=E142}"
                                                          />
                                                <Separator/>
                                                <MenuItem Header="Add to playlist" 
                                                          Icon="{ex:Icon Glyph=ED0E}" 
                                                          Command="{Binding AddToPlaylistCommand}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext.Id, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          />
                                                <Separator/>
                                                <MenuItem Header="Edit track" 
                                                          Command="{Binding EditTrackCommand}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext.Id, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          Icon="{ex:Icon Glyph=E70F}"
                                                          />

                                                <Separator/>
                                                <MenuItem Header="Show in File Explorer" 
                                                          Command="{Binding ShowInExplorerCommand}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext.Id, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          Icon="{ex:Icon Glyph=E8B7}"
                                                          />
                                            </ContextMenu>
                                        </Grid.ContextMenu>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="auto" MinWidth="50"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Track Number -->
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding TrackNumberDisplay}" 
                                                       FontSize="13" 
                                                       Foreground="{Binding DataContext.ForegroundColor, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource HexToBrushConverter}}"
                                                       Opacity="0.6"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"
                                                       Margin="0,0,12,0"/>

                                            <!-- Track Info -->
                                            <Grid Grid.Column="1" HorizontalAlignment="Stretch">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0"
                                                    Text="{Binding Title}" 
                                                    FontSize="12" 
                                                    FontWeight="Medium"
                                                    Foreground="{Binding DataContext.ForegroundColor, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource HexToBrushConverter}}"
                                                    TextTrimming="CharacterEllipsis"
                                                    TextWrapping="NoWrap"
                                                    />

                                                <TextBlock Grid.Row="1"
                                                    Text="{Binding ArtistNames}" 
                                                    FontSize="12" 
                                                    FontWeight="Light"
                                                    Foreground="{Binding DataContext.ForegroundColor, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource HexToBrushConverter}}"
                                                    Opacity="0.6"
                                                    TextTrimming="CharacterEllipsis"
                                                    TextWrapping="NoWrap"/>
                                            </Grid>

                                            <!-- Duration -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding FormattedDuration}" 
                                                       FontSize="12" 
                                                       Foreground="{Binding DataContext.ForegroundColor, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource HexToBrushConverter}}"
                                                       Opacity="0.6"
                                                       VerticalAlignment="Center"
                                                       Margin="16,0,0,0"/>
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
