<UserControl x:Class="MusicWrap.UI.Pages.MainWindow.AlbumTracksPage"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
         xmlns:local="clr-namespace:MusicWrap.UI.Pages.MainWindow"
         xmlns:vm="clr-namespace:MusicWrap.UI.ViewModels.Library"
         xmlns:uimodels="clr-namespace:MusicWrap.UI.Controls.Models"
         xmlns:converters="clr-namespace:MusicWrap.UI.Converters"
         mc:Ignorable="d" 
         d:DataContext="{d:DesignInstance Type=vm:AlbumTracksViewModel}"
         d:DesignHeight="450" d:DesignWidth="800"
         Foreground="{Binding ForegroundColor, Converter={StaticResource HexToBrushConverter}}"
         Background="Transparent">
    <UserControl.Resources>
        <converters:DiskNumberToVisibilityConverter x:Key="DiskNumberToVisibilityConverter"/>
        <converters:ItemCountToColumnsConverter x:Key="ItemCountToColumnsConverter"/>
    </UserControl.Resources>
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Album Header -->
        <StackPanel Grid.Row="0" Margin="0,8,0,8">
            <Grid Margin="0,0,24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Button Width="26" Height="26" Padding="0" VerticalAlignment="Top"
                        Grid.Column="0"
                        Foreground="{Binding ForegroundColor, Converter={StaticResource HexToBrushConverter}}"
                        Background="Transparent"
                        BorderThickness="0"
                        ToolTip="{Binding AlbumPlayTooltip}" 
                        Click="PlayPauseAlbum_Click"
                        >
                    <TextBlock FontFamily="{StaticResource SymbolThemeFontFamily}" Text="{Binding AlbumPlayGlyph}"/>
                </Button>
                <TextBlock Text="{Binding AlbumTitle}" 
                           Grid.Column="1"
                           FontSize="16" 
                           FontWeight="Bold"
                           Foreground="{Binding ForegroundColor, Converter={StaticResource HexToBrushConverter}}"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>
            <TextBlock FontSize="12" 
                       Foreground="{Binding ForegroundColor, Converter={StaticResource HexToBrushConverter}}"
                       Opacity="0.7"
                       Margin="0,4,0,0">
                <Run Text="{Binding AlbumArtists}"/>
                <Run Text=" • "/>
                <Run Text="{Binding AlbumYear}"/>
            </TextBlock>
        </StackPanel>

        <!-- Tracks List Grouped by Disk -->
        <ItemsControl Grid.Row="1"
                      ItemsSource="{Binding DiskGroups}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="0,0,0,24">
                        <!-- Disk Header (only show if there are multiple disks) -->
                        <TextBlock Text="{Binding DiskTitle}" 
                                   FontSize="14" 
                                   FontWeight="SemiBold"
                                   Foreground="{Binding DataContext.ForegroundColor, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource HexToBrushConverter}}"
                                   Opacity="0.8"
                                   Margin="0,0,0,8"
                                   Visibility="{Binding DiskNumber, Converter={StaticResource DiskNumberToVisibilityConverter}}"/>

                        <!-- Tracks in this disk -->
                        <uimodels:TracksView
                            ItemsSource="{Binding Tracks}"
                            AllTrackIds="{Binding DataContext.AllTrackIds, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            VisualMode="CompactNoCover"
                            IndexMode="TrackNumber"
                            UseColumnFlowPanel="True"
                            SelectionMode="Extended"
                            >
                            <uimodels:TracksView.ColumnFlowColumns>
                                <MultiBinding Converter="{StaticResource ItemCountToColumnsConverter}" ConverterParameter="10,600">
                                    <Binding Path="Tracks.Count"/>
                                    <Binding RelativeSource="{RelativeSource Self}" Path="ActualWidth"/>
                                </MultiBinding>
                            </uimodels:TracksView.ColumnFlowColumns>
                        </uimodels:TracksView>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
