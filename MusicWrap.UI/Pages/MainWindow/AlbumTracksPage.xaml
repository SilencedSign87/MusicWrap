<UserControl x:Class="MusicWrap.UI.Pages.MainWindow.AlbumTracksPage"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
         xmlns:local="clr-namespace:MusicWrap.UI.Pages.MainWindow"
         xmlns:vm="clr-namespace:MusicWrap.UI.ViewModels.Library"
         xmlns:converters="clr-namespace:MusicWrap.UI.Converters"
         mc:Ignorable="d" 
         d:DataContext="{d:DesignInstance Type=vm:AlbumTracksViewModel}"
         d:DesignHeight="450" d:DesignWidth="800"
         Foreground="{Binding ForegroundColor, Converter={StaticResource HexToBrushConverter}}"
         Background="Transparent">
    <UserControl.Resources>
        <converters:DiskNumberToVisibilityConverter x:Key="DiskNumberToVisibilityConverter"/>
    </UserControl.Resources>
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Album Header -->
        <StackPanel Grid.Row="0" Margin="0,8,0,16">
            <TextBlock Text="{Binding AlbumTitle}" 
                       FontSize="18" 
                       FontWeight="Bold"
                       Foreground="{Binding ForegroundColor, Converter={StaticResource HexToBrushConverter}}"
                       TextWrapping="Wrap"/>
            <TextBlock FontSize="13" 
                       Foreground="{Binding ForegroundColor, Converter={StaticResource HexToBrushConverter}}"
                       Opacity="0.7"
                       Margin="0,4,0,0">
                <Run Text="{Binding AlbumArtists}"/>
                <Run Text=" • "/>
                <Run Text="{Binding AlbumYear}"/>
            </TextBlock>
        </StackPanel>

        <!-- Tracks List Grouped by Disk -->
        <ItemsControl Grid.Row="1"
                      ItemsSource="{Binding DiskGroups}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="0,0,0,24">
                        <!-- Disk Header (only show if there are multiple disks) -->
                        <TextBlock Text="{Binding DiskTitle}" 
                                   FontSize="14" 
                                   FontWeight="SemiBold"
                                   Foreground="{Binding DataContext.ForegroundColor, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource HexToBrushConverter}}"
                                   Opacity="0.8"
                                   Margin="0,0,0,8"
                                   Visibility="{Binding DiskNumber, Converter={StaticResource DiskNumberToVisibilityConverter}}"/>

                        <!-- Tracks in this disk -->
                        <ItemsControl ItemsSource="{Binding Tracks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                            Padding="8,6"
                                            Margin="0,1"
                                            CornerRadius="4"
                                            MouseLeftButtonDown="StartPlayingFromTrack"
                                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Cursor="Hand">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#1f000000"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="False">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.ContextMenu>
                                            <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}" Placement="Right">
                                                <MenuItem Header="Play Now" 
                                                          Command="{Binding PlayTrackCommand}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext.Id, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.Icon>
                                                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE768;" FontSize="14"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="Play Next" 
                                                          Command="{Binding PlayNextCommand}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext.Id, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.Icon>
                                                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xECC8;" FontSize="14"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="Add to Queue" 
                                                          Command="{Binding AddToQueueCommand}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext.Id, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.Icon>
                                                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE142;" FontSize="14"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <Separator/>
                                                <MenuItem Header="Edit Track Info" 
                                                          Command="{Binding EditTrackCommand}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext.Id, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.Icon>
                                                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE70F;" FontSize="14"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <Separator/>
                                                <MenuItem Header="Show in File Explorer" 
                                                          Command="{Binding ShowInExplorerCommand}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext.Id, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.Icon>
                                                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE8B7;" FontSize="14"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="Properties" 
                                                          Command="{Binding ShowPropertiesCommand}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext.Id, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.Icon>
                                                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE946;" FontSize="14"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Track Number -->
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding TrackNumberDisplay}" 
                                                       FontSize="13" 
                                                       Foreground="{Binding DataContext.ForegroundColor, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource HexToBrushConverter}}"
                                                       Opacity="0.6"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"
                                                       Margin="0,0,12,0"/>

                                            <!-- Track Info -->
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Title}" 
                                                           FontSize="14" 
                                                           FontWeight="Medium"
                                                           Foreground="{Binding DataContext.ForegroundColor, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource HexToBrushConverter}}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding ArtistNames}" 
                                                           FontSize="12" 
                                                           Foreground="{Binding DataContext.ForegroundColor, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource HexToBrushConverter}}"
                                                           Opacity="0.6"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <!-- Duration -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding FormattedDuration}" 
                                                       FontSize="13" 
                                                       Foreground="{Binding DataContext.ForegroundColor, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource HexToBrushConverter}}"
                                                       Opacity="0.6"
                                                       VerticalAlignment="Center"
                                                       Margin="16,0,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
