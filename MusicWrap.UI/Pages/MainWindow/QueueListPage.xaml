<UserControl x:Class="MusicWrap.UI.Pages.MainWindow.QueueListPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MusicWrap.UI.Pages.MainWindow"
             xmlns:vm="clr-namespace:MusicWrap.UI.ViewModels.Library"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:QueueViewModel}"
             d:DesignHeight="700" d:DesignWidth="500">
    <UserControl.Resources>
        <DataTemplate x:Key="QueueItemTemplate" DataType="vm:QueueData">
            <Border x:Name="TrackContainer">
                <Grid Height="72">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="72"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- Image -->
                    <Image Grid.Column="0"
                       Width="64" Height="64" VerticalAlignment="Center"
                       Source="{Binding AlbumArt}"/>
                    <!-- Body -->
                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14" TextTrimming="WordEllipsis"/>
                            <TextBlock Text="{Binding ArtistString}" FontSize="12" Opacity="0.7" TextTrimming="WordEllipsis"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding DurationString}" Margin="8,0,8,0" VerticalAlignment="Center" Opacity="0.7"/>
                    </Grid>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                    <Setter TargetName="TrackContainer" Property="Background" Value="{StaticResource AccentBrush100}" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </UserControl.Resources>
    <Grid>
        <ListView
            Grid.Row="1"
            x:Name="QueueListView"
            ItemsSource="{Binding QueueDataList}"
            ItemTemplate="{StaticResource QueueItemTemplate}"
            SelectionMode="Extended"
            Padding="0"
            Margin="0"
            VirtualizingPanel.ScrollUnit="Pixel"
            VirtualizingPanel.IsContainerVirtualizable="True"
            VirtualizingPanel.IsVirtualizing="True"
            ScrollViewer.CanContentScroll="True"
            ScrollViewer.VerticalScrollBarVisibility="Auto"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            MouseDoubleClick="ListDoubleClickPlay"
            >
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Play now" />
                    <MenuItem Header="Play next" Click="PlayNext" />
                    <MenuItem Header="Remove" />
                    <Separator />
                    <MenuItem Header="Playlist" />
                </ContextMenu>
            </ListView.ContextMenu>
        </ListView>
    </Grid>
</UserControl>
