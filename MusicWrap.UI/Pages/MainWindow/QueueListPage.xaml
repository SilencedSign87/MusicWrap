<UserControl x:Class="MusicWrap.UI.Pages.MainWindow.QueueListPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MusicWrap.UI.Pages.MainWindow"
             xmlns:ex="clr-namespace:MusicWrap.UI.Helpers"
             xmlns:vm="clr-namespace:MusicWrap.UI.ViewModels.Library"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:QueueViewModel}"
             d:DesignHeight="700" d:DesignWidth="500">
    <UserControl.Resources>
        <DataTemplate x:Key="QueueItemTemplate" DataType="vm:QueueData">
            <Grid x:Name="TrackContainer" Height="48" HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48" />
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <!-- Image -->
                <Image
                    Grid.Column="0"
                    Width="40" Height="40"
                    Margin="4"
                    Source="{Binding AlbumArt}"
                    RenderOptions.BitmapScalingMode="LowQuality"
                    />
                <!-- Body -->
                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" x:Name="PlayingIcon" Visibility="Collapsed">
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe995;" FontSize="16" VerticalAlignment="Center" TextTrimming="WordEllipsis" Margin="2" Foreground="{StaticResource AccentBrush100}"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="TitleText" Text="{Binding Title}" FontWeight="SemiBold" FontSize="12" TextTrimming="WordEllipsis"/>
                        <TextBlock Text="{Binding ArtistString}" FontSize="11" Opacity="0.7" TextTrimming="WordEllipsis"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="{Binding DurationString}" Margin="8,0,8,0" VerticalAlignment="Center" Opacity="0.7"/>
                </Grid>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                    <Setter TargetName="TitleText" Property="Foreground" Value="{StaticResource AccentBrush100}" />
                    <Setter TargetName="PlayingIcon" Property="Visibility" Value="Visible" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </UserControl.Resources>
    <Grid>
        <ListView
            Grid.Row="1"
            x:Name="QueueListView"
            ItemsSource="{Binding QueueDataList}"
            ItemTemplate="{StaticResource QueueItemTemplate}"
            SelectionMode="Extended"
            Padding="0"
            Margin="0"
            VirtualizingPanel.ScrollUnit="Item"
            VirtualizingPanel.IsContainerVirtualizable="True"
            VirtualizingPanel.IsVirtualizing="True"
            ScrollViewer.CanContentScroll="True"
            ScrollViewer.VerticalScrollBarVisibility="Auto"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            MouseDoubleClick="ListDoubleClickPlay"
            >
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Height" Value="auto"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Play now" Click="PlaySelectedNow"  Icon="{ex:Icon Glyph=e768}"/>
                    <MenuItem Header="Play next" Click="PlayNext" Icon="{ex:Icon Glyph=ECC8}"/>
                    <MenuItem Header="Remove" Click="RemoveFromQueue" Icon="{ex:Icon Glyph=ecc9}" />
                    <Separator />
                    <MenuItem Header="Add to playlist" Icon="{ex:Icon Glyph=ED0E}" />
                </ContextMenu>
            </ListView.ContextMenu>
        </ListView>
    </Grid>
</UserControl>
