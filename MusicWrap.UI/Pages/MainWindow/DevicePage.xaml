<UserControl x:Class="MusicWrap.UI.Pages.MainWindow.DevicePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MusicWrap.UI.Pages.MainWindow"
             xmlns:vm="clr-namespace:MusicWrap.UI.ViewModels"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:DeviceViewModel}"
             d:Background="#1fffffff"
             d:DesignHeight="500" d:DesignWidth="300">
    <StackPanel Margin="16">
        <!-- Current Info -->

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Grid.Column="0">
                <TextBlock  Text="&#xe946;" FontFamily="Segoe Fluent Icons" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Text="Current device information" VerticalAlignment="Center" />
            </StackPanel>
            <Border Grid.Column="1" Padding="8,0,0,0">
                <Separator VerticalAlignment="Center" />
            </Border>
        </Grid>

        <StackPanel Margin="0,0,0,16">

            <TextBlock   Text="Current Device" FontSize="12" Margin="0,0,0,8" FontWeight="Medium" TextTrimming="WordEllipsis" />
            <TextBlock   Text="{Binding CurrentDeviceName}" FontSize="12" Margin="0,0,0,8" TextTrimming="WordEllipsis" TextAlignment="Right" />

            <TextBlock  Text="Current Sample rate" FontSize="12" Margin="0,0,0,8" FontWeight="Medium" TextTrimming="WordEllipsis"/>
            <TextBlock  FontSize="12" Margin="0,0,0,8" TextTrimming="WordEllipsis" TextAlignment="Right">
                <Run Text="{Binding CurrentSampleRate}" />
                <Run Text=" hz" />
            </TextBlock>

        </StackPanel>

        <Grid  Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Grid.Column="0">
                <TextBlock  Text="&#xe713;" FontFamily="Segoe Fluent Icons" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Text="Device settings" VerticalAlignment="Center" />
            </StackPanel>
            <Border Grid.Column="1" Padding="8,0,0,0">
                <Separator VerticalAlignment="Center" />
            </Border>
        </Grid>
        <!-- Settings -->
        <StackPanel Margin="0,0,0,16">

            <TextBlock Text="Device" FontSize="12" Margin="0,0,0,8" FontWeight="Medium" VerticalAlignment="Center" />
            <ComboBox
                      Margin="0,0,0,8" 
                      SelectedIndex="{Binding CurrentDeviceIndex}"
                      ItemsSource="{Binding AvailableDevices}"
                      SelectionChanged="DeviceChanged"
                      >
                <ComboBox.ItemTemplate>
                    <DataTemplate DataType="vm:DeviceDefinition">
                        <TextBlock Tag="{Binding Index}" Text="{Binding Name}" TextTrimming="WordEllipsis" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Text="Sample rate" FontSize="12" Margin="0,0,0,8" FontWeight="Medium" VerticalAlignment="Center" />
            <ComboBox  SelectedIndex="{Binding CurrentSampleRateIndex}" SelectionChanged="SampleRateChanged" Margin="0,0,0,8" >
                <ComboBoxItem Tag="auto" Content="Match track sample rate" />
                <ComboBoxItem Tag="44100" Content="44100 hz" />
                <ComboBoxItem Tag="48000" Content="48000 hz" />
                <ComboBoxItem Tag="88200" Content="88200 hz" />
                <ComboBoxItem Tag="96000" Content="96000 hz" />
                <ComboBoxItem Tag="176400" Content="176400 hz" />
                <ComboBoxItem Tag="192000" Content="192000 hz" />
            </ComboBox>
        </StackPanel>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Grid.Column="0">
                <TextBlock  Text="&#xE7E8;" FontFamily="Segoe Fluent Icons" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Text="App startup" VerticalAlignment="Center" />
            </StackPanel>
            <Border Grid.Column="1" Padding="8,0,0,0">
                <Separator VerticalAlignment="Center" />
            </Border>
        </Grid>

        <WrapPanel Orientation="Horizontal" Margin="0,0,0,16">
            <RadioButton GroupName="start"  Content="Resume playing" Margin="8,0" />
            <RadioButton GroupName="start" Content="Preserve queue and current track" Margin="8,0"/>
            <RadioButton GroupName="start" Content="Preserve queue" Margin="8,0"/>
            <RadioButton GroupName="start" Content="Nothing" Margin="8,0"/>
        </WrapPanel>

    </StackPanel>
</UserControl>
