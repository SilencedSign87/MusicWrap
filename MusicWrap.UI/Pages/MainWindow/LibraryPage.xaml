<UserControl x:Class="MusicWrap.UI.Pages.MainWindow.LibraryPage"
         x:Name="RootLibraryPage"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
         xmlns:local="clr-namespace:MusicWrap.UI.Pages.MainWindow"
         xmlns:ex="clr-namespace:MusicWrap.UI.Helpers"
         xmlns:converters="clr-namespace:MusicWrap.UI.Converters"
         xmlns:vm="clr-namespace:MusicWrap.UI.ViewModels.Library"
         xmlns:pages="clr-namespace:MusicWrap.UI.Pages"
         xmlns:controlsM="clr-namespace:MusicWrap.UI.Controls.Models"
         xmlns:vwp="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel"
         xmlns:selectors="clr-namespace:MusicWrap.UI.Selectors"
         mc:Ignorable="d" 
         Foreground="White"
         d:DataContext="{d:DesignInstance Type=vm:LibraryViewModel+AlbumGridRowModel}"
         d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <!-- Template for Album -->
        <DataTemplate x:Key="AlbumTemplate">
            <Button Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Width="150"
                    Height="194"
                    Cursor="Hand"
                    Tag="{Binding Id}"
                    Click="AlbumButton_Click"
                    >
                <local:AlbumPage DataContext="{Binding}"/>
            </Button>
        </DataTemplate>

        <!-- Template for Track List Placeholder -->
        <DataTemplate x:Key="TrackListTemplate">
            <Border 
                Margin="0,8"
                CornerRadius="4"
                HorizontalAlignment="Stretch"
                BorderThickness="1"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                >
                <Border.Background>
                    <ImageBrush 
                        ImageSource="{Binding ImagePath , Converter={StaticResource PathToImageConverter}, ConverterParameter=512}" 
                        RenderOptions.BitmapScalingMode="HighQuality"
                        Stretch="UniformToFill"/>
                </Border.Background>
                <Grid>
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <ContentControl x:Name="TracksContentPlaceholder"
                                Grid.Row="0"
                                Margin="0,0,0,0"
                                Loaded="TracksContentPlaceholder_Loaded"/>

                        <!-- Close Button -->
                        <Button x:Name="CloseTracksButton"
                        Content="✕"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Padding="8,4"
                        Background="Transparent"
                        Foreground="{Binding ForegroundColor, Converter={StaticResource HexToBrushConverter}}"
                        BorderThickness="0"
                        FontSize="14"
                        Cursor="Hand"
                        Click="CloseTracksButton_Click"/>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Template Selector -->
        <selectors:AlbumItemTemplateSelector x:Key="AlbumItemSelector"
                                         AlbumTemplate="{StaticResource AlbumTemplate}"
                                         TrackListTemplate="{StaticResource TrackListTemplate}"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" MinWidth="200" MaxWidth="350"/>
            <ColumnDefinition Width="6"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <!-- Library entries list -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <Menu Grid.Row="0" VerticalAlignment="Center">
                <MenuItem Header="Library" Icon="{ex:Icon Glyph=E8F1}">
                    <MenuItem Header="Rescan directories" Icon="{ex:Icon Glyph=E895}" Command="{Binding RescanAllDirectoriesCommand}"/>
                    <Separator/>
                    <MenuItem Header="Add Folder" Icon="{ex:Icon Glyph=E8F4}" Command="{Binding AddFolderCommand}"/>
                    <MenuItem Header="Add Files" Icon="{ex:Icon Glyph=E710}" Command="{Binding AddFilesCommand}"/>
                    <Separator/>
                    <MenuItem Header="Refresh library" Icon="{ex:Icon Glyph=E72C}" Command="{Binding RefreshCommand}"/>
                </MenuItem>
                <MenuItem Header="View" Icon="{ex:Icon Glyph=E7B3}">
                    <MenuItem Header="Albums" 
                              Command="{Binding SetViewModeCommand}" 
                              CommandParameter="Album"
                              IsCheckable="True" 
                              IsChecked="{Binding IsAlbumView, Mode=OneWay}"
                              Icon="{ex:Icon Glyph=E93C}"
                              />

                    <MenuItem Header="Artist" 
                              Command="{Binding SetViewModeCommand}" 
                              CommandParameter="Artist"
                              IsCheckable="True" 
                              IsChecked="{Binding IsArtistView, Mode=OneWay}"
                              Icon="{ex:Icon Glyph=E77B}"
                              />

                    <MenuItem Header="Genre" 
                              Command="{Binding SetViewModeCommand}" 
                              CommandParameter="Genre"
                              IsCheckable="True" 
                              IsChecked="{Binding IsGenreView, Mode=OneWay}"
                              Icon="{ex:Icon Glyph=E8D6}"
                              />

                    <MenuItem Header="Decade" 
                              Command="{Binding SetViewModeCommand}" 
                              CommandParameter="Decade"
                              IsCheckable="True" 
                              IsChecked="{Binding IsDecadeView, Mode=OneWay}"
                              Icon="{ex:Icon Glyph=E787}"
                              />

                    <Separator/>
                    <MenuItem Header="Ascending" 
                              Command="{Binding SetAscendingCommand}"
                              IsCheckable="True" 
                              IsChecked="{Binding Ascending, Mode=OneWay}"
                              Icon="{ex:Icon Glyph=E74A, FontSize=12}"
                              />

                    <MenuItem Header="Descending" 
                              Command="{Binding SetDescendingCommand}"
                              IsCheckable="True" 
                              IsChecked="{Binding Ascending, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                              Icon="{ex:Icon Glyph=E74B, FontSize=12}"
                              />
                </MenuItem>
            </Menu>
            <Border Grid.Row="1" Padding="4,0" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ProgressBar
                    Minimum="0"
                    Maximum="100"
                    Foreground="{StaticResource AccentBrush80}" 
                    Background="#111111" 
                    Value="{Binding LoadingProgressValue}"
                    IsIndeterminate="{Binding IsLoadingIndeterminate}"/>
            </Border>
            <ListView
                    x:Name="EntriesListView"
                    ItemsSource="{Binding EntriesViewSource.View}"
                    SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                    Grid.Row="2"
                    SelectionMode="Single"
                    HorizontalAlignment="Stretch"
                    PreviewKeyDown="EntriesListView_PreviewKeyDown"
                    VirtualizingPanel.IsVirtualizing="True"
                    VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                    VirtualizingPanel.VirtualizationMode="Recycling"
                    VirtualizingPanel.ScrollUnit="Item"
                    VirtualizingPanel.CacheLength="2,2"
                    VirtualizingPanel.CacheLengthUnit="Page"
                    ScrollViewer.CanContentScroll="True"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    Background="{StaticResource BackgroundLayer}"
                    >
                <ListView.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <Border Background="Transparent" 
                                        Padding="8,4" 
                                        BorderThickness="0,0,0,1"
                                        BorderBrush="{StaticResource StrokeDivider}"
                                        Margin="0,8,0,0">
                                    <TextBlock Text="{Binding Name}" 
                                               FontSize="14" 
                                               FontWeight="SemiBold" 
                                               Foreground="White"/>
                                </Border>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="{x:Type GroupItem}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type GroupItem}">
                                            <StackPanel>
                                                <ContentPresenter />
                                                <ItemsPresenter />
                                            </StackPanel>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GroupStyle.ContainerStyle>
                    </GroupStyle>
                </ListView.GroupStyle>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Height" Value="auto"/>
                        <Setter Property="Padding" Value="4"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate DataType="LibraryEntry">
                        <Grid 
                            Margin="0"
                            ToolTipService.ToolTip="{Binding Title}"
                            HorizontalAlignment="Stretch">
                            <Grid.ContextMenu>
                                <ContextMenu Opened="LibraryContextMenu_Opened">
                                    <MenuItem Header="Play" Icon="{ex:Icon Glyph=E768}"/>
                                    <MenuItem Header="Play next" Icon="{ex:Icon Glyph=ECC8}"/>
                                    <MenuItem Header="Add to queue" Icon="{ex:Icon Glyph=E90B}"/>
                                    <Separator/>
                                    <controlsM:TrackToPlaylistMenu x:Name="LibraryTrackToPlaylistMenu"/>
                                    <Separator/>
                                    <MenuItem Header="Edit" Icon="{ex:Icon Glyph=E70F}"/>
                                </ContextMenu>
                            </Grid.ContextMenu>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image
                                Grid.Column="0"
                                Source="{Binding ImagePath, Converter={StaticResource PathToImageConverter}, ConverterParameter=42}"
                                Width="42"
                                Height="42"
                                Stretch="UniformToFill"
                                RenderOptions.BitmapScalingMode="LowQuality"
                                />
                            <Grid Grid.Column="2">
                                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                                    <TextBlock Text="{Binding Title}" 
                                           FontSize="12" 
                                           FontWeight="Normal"
                                           TextTrimming="CharacterEllipsis"
                                           />
                                    <TextBlock Text="{Binding Description}" 
                                           FontSize="12" 
                                           Opacity="0.7"
                                           TextTrimming="CharacterEllipsis"
                                           />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
        <GridSplitter Grid.Column="1" />
        <!-- Selected content -->
        <Grid Grid.Column="2" Background="{StaticResource BackgroundSmoke}">
            <ListBox x:Name="AlbumsViewport"
                     ItemsSource="{Binding GridRows}"
                     SelectionChanged="AlbumsViewport_SelectionChanged"
                     SelectionMode="Single"
                     IsSynchronizedWithCurrentItem="False"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="8"
                     Loaded="AlbumsViewport_Loaded"
                     SizeChanged="AlbumsViewport_SizeChanged"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.CanContentScroll="True"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     VirtualizingPanel.ScrollUnit="Pixel"
                     VirtualizingPanel.CacheLength="2,2"
                     VirtualizingPanel.CacheLengthUnit="Page">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Focusable" Value="False"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                        <DataTemplate DataType="AlbumGridRowModel">
                            <Grid Margin="0,0,0,16" HorizontalAlignment="Stretch">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <ItemsControl Grid.Row="0" ItemsSource="{Binding Albums}" HorizontalAlignment="Stretch">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="{Binding Source={x:Reference RootLibraryPage}, Path=DataContext.LayoutColumns}" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="AlbumData">
                                            <Button 
                                            BorderThickness="0"
                                            Padding="0"
                                            Width="150"
                                            Height="194"
                                            Cursor="Hand"
                                            Click="AlbumButton_Click"
                                            Margin="0,0,16,0"
                                            >
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="OverridesDefaultStyle" Value="True"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}"
                                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                                            BorderThickness="{TemplateBinding BorderThickness}">
                                                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                                <Button.Background>
                                                    <MultiBinding Converter="{StaticResource SelectedAlbumBackgroundConverter}">
                                                        <Binding Path="Id"/>
                                                        <Binding Source="{x:Reference RootLibraryPage}" Path="DataContext.ExpandedAlbumId"/>
                                                        <Binding Path="DominantColor"/>
                                                    </MultiBinding>
                                                </Button.Background>
                                                <local:AlbumPage DataContext="{Binding}"/>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Border Grid.Row="1"
                                    DataContext="{Binding}"
                                    Visibility="{Binding ExpandedAlbumId, Converter={StaticResource NullToCollapseConverter}}"
                                    Margin="0,8,0,0"
                                    CornerRadius="4"
                                        BorderThickness="0"
                                    HorizontalAlignment="Stretch">
                                    <Border.Background>
                                        <ImageBrush 
                                        ImageSource="{Binding ExpandedImagePath, Converter={StaticResource PathToImageConverter}, ConverterParameter=blur:512}" 
                                        RenderOptions.BitmapScalingMode="HighQuality"
                                        Stretch="UniformToFill"/>
                                    </Border.Background>
                                    <Grid Margin="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <ContentControl 
                                        x:Name="TracksContentPlaceholder"
                                        Grid.Row="0"
                                        Loaded="TracksContentPlaceholder_Loaded"
                                        DataContext="{Binding}"
                                        HorizontalContentAlignment="Stretch"
                                        VerticalContentAlignment="Top"/>

                                        <!-- Close Button -->
                                        <Button 
                                        Content="✕"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Padding="8,4"
                                        Background="Transparent"
                                        Foreground="{Binding ExpandedForegroundColor, Converter={StaticResource HexToBrushConverter}}"
                                        BorderThickness="0"
                                        FontSize="14"
                                        Cursor="Hand"
                                        Click="CloseTracksButton_Click"
                                        Tag="{Binding}"/>
                                    </Grid>
                                </Border>

                            </Grid>
                        </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Grid>
</UserControl>
