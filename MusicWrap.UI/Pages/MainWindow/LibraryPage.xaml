<UserControl x:Class="MusicWrap.UI.Pages.MainWindow.LibraryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MusicWrap.UI.Pages.MainWindow"
             xmlns:converters="clr-namespace:MusicWrap.UI.Converters"
             xmlns:vm="clr-namespace:MusicWrap.UI.ViewModels.Library"
             mc:Ignorable="d" 
             Foreground="White"
             d:DataContext="{d:DesignInstance Type=vm:LibraryViewModel}"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <converters:PathToImageConverter x:Key="PathToImageConverter"/>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <!-- Library entries list -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <Menu Grid.Row="0">
                <MenuItem Header="Add">
                    <MenuItem.Icon>
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe710;" />
                    </MenuItem.Icon>
                    <MenuItem Header="Add Folder" Command="{Binding AddFolderCommand}"/>
                    <MenuItem Header="Add Files" Command="{Binding AddFilesCommand}"/>
                    <Separator/>
                    <MenuItem Header="Refresh library" Command="{Binding RefreshCommand}"/>
                </MenuItem>
                <MenuItem Header="View">
                    <MenuItem.Icon>
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe7b3;" />
                    </MenuItem.Icon>
                    <MenuItem Header="Albums" 
                              Command="{Binding SetViewModeCommand}" 
                              CommandParameter="Album"
                              IsCheckable="True" 
                              IsChecked="{Binding IsAlbumView, Mode=OneWay}">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe93c;" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Artist" 
                              Command="{Binding SetViewModeCommand}" 
                              CommandParameter="Artist"
                              IsCheckable="True" 
                              IsChecked="{Binding IsArtistView, Mode=OneWay}">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe77b;" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Genre" 
                              Command="{Binding SetViewModeCommand}" 
                              CommandParameter="Genre"
                              IsCheckable="True" 
                              IsChecked="{Binding IsGenreView, Mode=OneWay}">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe8d6;" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Decade" 
                              Command="{Binding SetViewModeCommand}" 
                              CommandParameter="Decade"
                              IsCheckable="True" 
                              IsChecked="{Binding IsDecadeView, Mode=OneWay}">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe787;" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Ascending" 
                              Command="{Binding SetAscendingCommand}"
                              IsCheckable="True" 
                              IsChecked="{Binding Ascending, Mode=OneWay}">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe74a;" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Descending" 
                              Command="{Binding SetDescendingCommand}"
                              IsCheckable="True" 
                              IsChecked="{Binding Ascending, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe74b;" />
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
            </Menu>
            <ListView
                    x:Name="EntriesListView"
                    ItemsSource="{Binding EntriesViewSource.View}"
                    Grid.Row="1"
                    SelectionMode="Single"
                    HorizontalAlignment="Stretch"
                    PreviewKeyDown="EntriesListView_PreviewKeyDown"
                    VirtualizingPanel.IsVirtualizing="True"
                    VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                    VirtualizingPanel.VirtualizationMode="Recycling"
                    VirtualizingPanel.ScrollUnit="Pixel"
                    VirtualizingPanel.CacheLength="2,2"
                    VirtualizingPanel.CacheLengthUnit="Page"
                    ScrollViewer.CanContentScroll="False"
                    ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                    Background="#1e1e1e"
                    >
                <ListView.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <Border Background="Transparent" 
                                        Padding="8,4" 
                                        BorderThickness="0,0,0,1"
                                        BorderBrush="{StaticResource StrokePrimaryBrush}"
                                        Margin="0,16,0,0">
                                    <TextBlock Text="{Binding Name}" 
                                               FontSize="14" 
                                               FontWeight="SemiBold" 
                                               Foreground="White"/>
                                </Border>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="{x:Type GroupItem}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type GroupItem}">
                                            <StackPanel>
                                                <ContentPresenter />
                                                <ItemsPresenter />
                                            </StackPanel>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GroupStyle.ContainerStyle>
                    </GroupStyle>
                </ListView.GroupStyle>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Height" Value="auto"/>
                        <Setter Property="Padding" Value="4"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate DataType="vm:LibraryEntry">
                        <StackPanel 
                            Orientation="Horizontal" 
                            Margin="0"
                            ToolTipService.ToolTip="{Binding Title}"
                            HorizontalAlignment="Stretch">
                            <Image
                                Source="{Binding ImagePath, Converter={StaticResource PathToImageConverter}, ConverterParameter=64}"
                                Width="64"
                                Height="64"
                                Stretch="UniformToFill"
                                />
                            <StackPanel Orientation="Vertical" Margin="8,0,0,0" VerticalAlignment="Center" Width="175">
                                <TextBlock Text="{Binding Title}" 
                                           FontSize="14" 
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           />
                                <TextBlock Text="{Binding Description}" 
                                           FontSize="12" 
                                           Opacity="0.7"
                                           TextTrimming="CharacterEllipsis"
                                           />
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
        <!-- Selected content -->
        <Grid Grid.Column="1">
            <WrapPanel ItemWidth="150" ItemHeight="150" x:Name="AlbumWrapPanel">
                
            </WrapPanel>
        </Grid>
    </Grid>
</UserControl>
