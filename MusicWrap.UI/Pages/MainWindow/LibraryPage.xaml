<UserControl x:Class="MusicWrap.UI.Pages.MainWindow.LibraryPage"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
         xmlns:local="clr-namespace:MusicWrap.UI.Pages.MainWindow"
         xmlns:ex="clr-namespace:MusicWrap.UI.Helpers"
         xmlns:converters="clr-namespace:MusicWrap.UI.Converters"
         xmlns:vm="clr-namespace:MusicWrap.UI.ViewModels.Library"
         xmlns:vwp="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel"
         xmlns:selectors="clr-namespace:MusicWrap.UI.Selectors"
         mc:Ignorable="d" 
         Foreground="White"
         d:DataContext="{d:DesignInstance Type=vm:LibraryViewModel}"
         d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <!-- Template for Album -->
        <DataTemplate x:Key="AlbumTemplate">
            <Button Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Width="200"
                    Height="250"
                    Cursor="Hand"
                    Tag="{Binding Id}"
                    Click="AlbumButton_Click"
                    >
                <local:AlbumPage DataContext="{Binding}"/>
            </Button>
        </DataTemplate>

        <!-- Template for Track List Placeholder -->
        <DataTemplate x:Key="TrackListTemplate">
            <Border Background="{Binding DominantColor, Converter={StaticResource HexToBrushConverter}}"
                Margin="0,8"
                CornerRadius="4"
                Width="{Binding RelativeSource={RelativeSource AncestorType=Grid}, Path=ActualWidth}"
                HorizontalAlignment="Left">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <ContentControl x:Name="TracksContentPlaceholder"
                                Grid.Row="0"
                                Margin="0,0,0,0"
                                Loaded="TracksContentPlaceholder_Loaded"/>

                    <!-- Close Button -->
                    <Button x:Name="CloseTracksButton"
                        Content="✕"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Padding="8,4"
                        Background="Transparent"
                        Foreground="{Binding ForegroundColor, Converter={StaticResource HexToBrushConverter}}"
                        BorderThickness="0"
                        FontSize="14"
                        Cursor="Hand"
                        Click="CloseTracksButton_Click"/>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Template Selector -->
        <selectors:AlbumItemTemplateSelector x:Key="AlbumItemSelector"
                                         AlbumTemplate="{StaticResource AlbumTemplate}"
                                         TrackListTemplate="{StaticResource TrackListTemplate}"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <!-- Library entries list -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <Menu Grid.Row="0">
                <MenuItem Header="Add" Icon="{ex:Icon Glyph=E710}">
                    <MenuItem Header="Add Folder" Command="{Binding AddFolderCommand}"/>
                    <MenuItem Header="Add Files" Command="{Binding AddFilesCommand}"/>
                    <Separator/>
                    <MenuItem Header="Refresh library" Command="{Binding RefreshCommand}"/>
                </MenuItem>
                <MenuItem Header="View" Icon="{ex:Icon Glyph=E7B3}">
                    <MenuItem Header="Albums" 
                              Command="{Binding SetViewModeCommand}" 
                              CommandParameter="Album"
                              IsCheckable="True" 
                              IsChecked="{Binding IsAlbumView, Mode=OneWay}"
                              Icon="{ex:Icon Glyph=E93C}"
                              />

                    <MenuItem Header="Artist" 
                              Command="{Binding SetViewModeCommand}" 
                              CommandParameter="Artist"
                              IsCheckable="True" 
                              IsChecked="{Binding IsArtistView, Mode=OneWay}"
                              Icon="{ex:Icon Glyph=E77B}"
                              />

                    <MenuItem Header="Genre" 
                              Command="{Binding SetViewModeCommand}" 
                              CommandParameter="Genre"
                              IsCheckable="True" 
                              IsChecked="{Binding IsGenreView, Mode=OneWay}"
                              Icon="{ex:Icon Glyph=E8D6}"
                              />

                    <MenuItem Header="Decade" 
                              Command="{Binding SetViewModeCommand}" 
                              CommandParameter="Decade"
                              IsCheckable="True" 
                              IsChecked="{Binding IsDecadeView, Mode=OneWay}"
                              Icon="{ex:Icon Glyph=E787}"
                              />

                    <Separator/>
                    <MenuItem Header="Ascending" 
                              Command="{Binding SetAscendingCommand}"
                              IsCheckable="True" 
                              IsChecked="{Binding Ascending, Mode=OneWay}"
                              Icon="{ex:Icon Glyph=E74A}"
                              />

                    <MenuItem Header="Descending" 
                              Command="{Binding SetDescendingCommand}"
                              IsCheckable="True" 
                              IsChecked="{Binding Ascending, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                              Icon="{ex:Icon Glyph=E74B}"
                              />
                </MenuItem>
            </Menu>
            <ListView
                    x:Name="EntriesListView"
                    ItemsSource="{Binding EntriesViewSource.View}"
                    SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                    Grid.Row="1"
                    SelectionMode="Single"
                    HorizontalAlignment="Stretch"
                    PreviewKeyDown="EntriesListView_PreviewKeyDown"
                    VirtualizingPanel.IsVirtualizing="True"
                    VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                    VirtualizingPanel.VirtualizationMode="Recycling"
                    VirtualizingPanel.ScrollUnit="Pixel"
                    VirtualizingPanel.CacheLength="2,2"
                    VirtualizingPanel.CacheLengthUnit="Page"
                    ScrollViewer.CanContentScroll="True"
                    ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                    Background="{StaticResource BackgroundLayer}"
                    >
                <ListView.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <Border Background="Transparent" 
                                        Padding="8,4" 
                                        BorderThickness="0,0,0,1"
                                        BorderBrush="{StaticResource StrokeDivider}"
                                        Margin="0,16,0,0">
                                    <TextBlock Text="{Binding Name}" 
                                               FontSize="14" 
                                               FontWeight="SemiBold" 
                                               Foreground="White"/>
                                </Border>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="{x:Type GroupItem}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type GroupItem}">
                                            <StackPanel>
                                                <ContentPresenter />
                                                <ItemsPresenter />
                                            </StackPanel>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GroupStyle.ContainerStyle>
                    </GroupStyle>
                </ListView.GroupStyle>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Height" Value="auto"/>
                        <Setter Property="Padding" Value="4"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate DataType="LibraryEntry">
                        <StackPanel 
                            Orientation="Horizontal" 
                            Margin="0"
                            ToolTipService.ToolTip="{Binding Title}"
                            HorizontalAlignment="Stretch">
                            <StackPanel.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Play" Icon="{ex:Icon Glyph=E768}"/>
                                    <MenuItem Header="Play next" Icon="{ex:Icon Glyph=ECC8}"/>
                                    <MenuItem Header="Add to queue" Icon="{ex:Icon Glyph=E90B}"/>
                                    <Separator/>
                                    <MenuItem Header="Add to playlist" Icon="{ex:Icon Glyph=ED0E}"/>
                                    <Separator/>
                                    <MenuItem Header="Edit" Icon="{ex:Icon Glyph=E70F}"/>
                                </ContextMenu>
                            </StackPanel.ContextMenu>
                            <Image
                                Source="{Binding ImagePath, Converter={StaticResource PathToImageConverter}, ConverterParameter=64}"
                                Width="64"
                                Height="64"
                                Stretch="UniformToFill"
                                RenderOptions.BitmapScalingMode="LowQuality"
                                />
                            <StackPanel Orientation="Vertical" Margin="8,0,0,0" VerticalAlignment="Center" Width="175">
                                <TextBlock Text="{Binding Title}" 
                                           FontSize="14" 
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           />
                                <TextBlock Text="{Binding Description}" 
                                           FontSize="12" 
                                           Opacity="0.7"
                                           TextTrimming="CharacterEllipsis"
                                           />
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
        <!-- Selected content -->
        <Grid Grid.Column="1" Background="{StaticResource BackgroundSmoke}">
            <!-- Show albums grid for all view modes -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          CanContentScroll="True"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="16" x:Name="AlbumWrapper">
                     <!--Albums WrapPanel with dynamic track list insertion--> 
                    <ItemsControl ItemsSource="{Binding AlbumsForSelectedEntry}"
                                  ItemTemplateSelector="{StaticResource AlbumItemSelector}"
                                  x:Name="AlbumsItemsControl"
                                  ScrollViewer.CanContentScroll="True"
                                  >
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
