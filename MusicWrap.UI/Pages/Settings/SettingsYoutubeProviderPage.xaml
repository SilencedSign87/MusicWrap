<UserControl x:Class="MusicWrap.UI.Pages.Settings.SettingsYoutubeProviderPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MusicWrap.UI.Pages.Settings"
             xmlns:vm="clr-namespace:MusicWrap.UI.ViewModels.Settings"
             xmlns:controls="clr-namespace:MusicWrap.UI.Controls"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:SettingsYoutubeViewModel}"
             d:Foreground="white"
             d:Background="#080808"
             d:DesignHeight="800" d:DesignWidth="400">

    <StackPanel Margin="16">
        <controls:SectionTitleSeparator Title="FFmpeg" IconGlyph="&#xE950;" Margin="0,8" />
        <CheckBox
            Margin="8,0,0,8"
            Content="Use custom ffmpeg.exe path"
            IsChecked="{Binding UseCustomFfmpegPath, Mode=TwoWay}" />
        <Grid Margin="8,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <controls:CompactInputField
                Grid.Column="0"
                Text="{Binding CustomFfmpegPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                IsEnabled="{Binding UseCustomFfmpegPath}"
                PlaceholderText="Path to FFmpeg.exe"
                >
                <controls:CompactInputField.BeforeContent>
                    <TextBlock FontFamily="{StaticResource SymbolThemeFontFamily}" Text="&#xED25;"/>
                </controls:CompactInputField.BeforeContent>

            </controls:CompactInputField>

            <Button
                Grid.Column="1"
                Margin="8,0,0,0"
                Padding="10,4"
                Content="Browse..."
                Style="{StaticResource DefaultButton}"
                Command="{Binding BrowseForFfmpegPathCommand}"
                IsEnabled="{Binding UseCustomFfmpegPath}" />
        </Grid>

        <Border Margin="8,0,0,16" Padding="8" CornerRadius="6" Background="#14000000">
            <StackPanel>
                <TextBlock Text="How to set up FFmpeg:" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBlock Text="1. Download FFmpeg from the official website." />
                <TextBlock Text="2. Extract it somewhere permanent." />
                <TextBlock Text="3. Select ffmpeg.exe (usually in the bin folder)." />
                <StackPanel Orientation="Horizontal" Margin="0,16">
                    <Button Content="Open official download page"
                            Style="{StaticResource TransparentButton}"
                            Command="{Binding OpenffmpegDownloadPageCommand}"
                            Padding="10,4" />
                </StackPanel>
            </StackPanel>
        </Border>
        <controls:SectionTitleSeparator Title="FFmpeg" IconGlyph="&#xE950;" Margin="0,8" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Preferred audio format:" Margin="0,0,8,0"/>
            <ComboBox Grid.Column="1" Width="100">
                <ComboBoxItem Content=".mp3" />
                <ComboBoxItem Content=".m4a" />
                <ComboBoxItem Content=".opus" />
                <ComboBoxItem Content=".flac" />
                <ComboBoxItem Content=".wav" />
            </ComboBox>
        </Grid>
    </StackPanel>
</UserControl>
