<UserControl x:Class="MusicWrap.UI.Pages.Settings.SettingsGeneralPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MusicWrap.UI.Pages.Settings"
      xmlns:vm="clr-namespace:MusicWrap.UI.ViewModels.Settings"
      mc:Ignorable="d" 
             d:Background="#1fffffff"
      d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel Margin="16">
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Grid.Column="0">
                <TextBlock  Text="&#xE7E8;" FontFamily="Segoe Fluent Icons" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Text="App startup" VerticalAlignment="Center" />
            </StackPanel>
            <Border Grid.Column="1" Padding="8,0,0,0">
                <Separator VerticalAlignment="Center" />
            </Border>
        </Grid>

        <WrapPanel Orientation="Horizontal" Margin="0,0,0,16">
            <RadioButton GroupName="start"
                 Content="Resume playing"
                 Margin="8,0"
                 IsChecked="{Binding ResumePlayback, Mode=TwoWay}" />

            <RadioButton GroupName="start"
                 Content="Preserve queue and current track"
                 Margin="8,0"
                 IsChecked="{Binding RestoreQueueAndIndexOnly, Mode=TwoWay}" />

            <RadioButton GroupName="start"
                 Content="Preserve queue"
                 Margin="8,0"
                 IsChecked="{Binding RestoreQueueOnly, Mode=TwoWay}" />

            <RadioButton GroupName="start"
                 Content="Nothing"
                 Margin="8,0"
                 IsChecked="{Binding StartClean, Mode=TwoWay}" />
        </WrapPanel>
    </StackPanel>
</UserControl>
