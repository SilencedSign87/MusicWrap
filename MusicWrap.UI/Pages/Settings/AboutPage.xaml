<UserControl x:Class="MusicWrap.UI.Pages.Settings.AboutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MusicWrap.UI.Pages.Settings"
             xmlns:vm="clr-namespace:MusicWrap.UI.ViewModels.Settings"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Foreground="White"
             d:DataContext="{d:DesignInstance Type=vm:AboutViewModel}"
             >
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Padding="8" Grid.Column="0">
                <Image Source="/Resources/icon.ico" Width="48" Height="48"/>
            </Border>
            <StackPanel Grid.Column="1">
                <TextBlock Text="{Binding AppName}" FontSize="16" FontWeight="Bold"/>
                <TextBlock Margin="0,4">
                    <Run Text="Version: "/>
                    <Run Text="{Binding AppVersion}"/>
                </TextBlock>
                <TextBlock>
                    <Hyperlink NavigateUri="https://github.com/SilencedSign87" RequestNavigate="Hyperlink_RequestNavigate">
                        Copyright: © 2026 SilencedSign87
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </Grid>
        <StackPanel Grid.Row="1" Margin="0,16,0,0">
            <TextBlock Text="Credits:"/>
            <Separator Margin="0,4"/>
            <ItemsControl
                ItemsSource="{Binding Credits}"
                Background="{StaticResource BackgroundSmoke}"
                >
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:Credits">
                        <Border Padding="12,8">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="48"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0">
                                    <TextBlock Text="{Binding IconGlyph}" FontFamily="Segoe Fluent Icons" FontSize="24" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Description}" FontSize="12" Opacity="0.7"/>
                                </StackPanel>
                                <Border Grid.Column="2">
                                    <Button Style="{StaticResource SubtleButton}" Padding="8" HorizontalAlignment="Center" VerticalAlignment="Center" Click="Button_Click">
                                        <TextBlock FontFamily="{StaticResource SymbolThemeFontFamily}" Text="&#xE8A7;"/>
                                    </Button>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Grid>
</UserControl>
