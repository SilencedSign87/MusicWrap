<UserControl x:Class="MusicWrap.UI.Pages.PlayerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MusicWrap.UI.Pages"
             xmlns:mw="clr-namespace:MusicWrap.UI.Pages.MainWindow"
             xmlns:vm="clr-namespace:MusicWrap.UI.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="80" 
             d:DesignWidth="1200"
             d:DataContext="{d:DesignInstance Type=vm:PlayerViewModel}"
             Foreground="White"
             >
    <Border 
        Padding="4"
        Background="{StaticResource BackgroundLayer}"
            >

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition MaxWidth="1000"/>
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <!--Music info-->
            <Grid Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="56" />
                    <ColumnDefinition />
                    <ColumnDefinition Width="56" />
                </Grid.ColumnDefinitions>
                <Image
                    Grid.Column="0"
                    Source="{Binding CurrentTrackImage}"
                    Height="56"
                    Width="56"
                    Stretch="UniformToFill"
                    RenderOptions.BitmapScalingMode="HighQuality"
                />
                <StackPanel Grid.Column="1" Orientation="Vertical" Margin="8" VerticalAlignment="Center">
                    <TextBlock FontSize="14" 
                               FontWeight="SemiBold" 
                               Text="{Binding CurrentTrackTitle}"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock FontSize="12" 
                               FontWeight="Light" 
                               Opacity="0.7"
                               Text="{Binding CurrentTrackArtists}"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <Grid Grid.Column="2">
                    <Button x:Name="PlusButton" Style="{StaticResource SubtleButton}" Click="PlusButton_Click" Width="40" Height="40" Padding="0">
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe710;" FontSize="20"/>
                    </Button>
                    <Popup
                        x:Name="PlusPopup"
                        PlacementTarget="{Binding ElementName=PlusButton}"
                        Placement="Top"
                        PopupAnimation="Slide"
                        AllowsTransparency="True"
                        HorizontalOffset="8"
                        StaysOpen="False">
                        <Border>
                            <Border Background="{StaticResource BackgroundFloating}" 
                            BorderBrush="{StaticResource StrokeFloating}" 
                                CornerRadius="8" 
                                Margin="8,16"
                                Width="100"
                                BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000"
                                        BlurRadius="16"
                                        ShadowDepth="4"
                                        Direction="270"
                                        Opacity="0.5"/>
                                </Border.Effect>
                                <StackPanel>
                                    <Button Style="{StaticResource SubtleButton}">Item 1</Button>
                                </StackPanel>
                            </Border>
                        </Border>
                    </Popup>
                </Grid>
            </Grid>
            <!--Controls-->
            <Grid Grid.Column="1" Margin="8,0" HorizontalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="RepeadButton" Style="{StaticResource SubtleButton}" Padding="0" Width="40" Height="40" ToolTip="Repeat">
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe8ee;" FontSize="14"/>
                    </Button>
                    <Button x:Name="PrevButton" Style="{StaticResource SubtleButton}" Padding="0" Width="40" Height="40" ToolTip="Previous track"
                            Command="{Binding PreviousCommand}"
                            >
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe892;" FontSize="14"/>
                    </Button>
                    <Button x:Name="PlayButton" Style="{StaticResource SubtleButton}" Padding="0" Width="40" Height="40"
                            Command="{Binding PlayPauseCommand}"
                            >
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="{Binding PlayPauseIcon}" FontSize="20"/>
                    </Button>
                    <Button x:Name="NextButton" Style="{StaticResource SubtleButton}" Padding="0" Width="40" Height="40" ToolTip="Next track"
                            Command="{Binding NextCommand}"
                            >
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe893;" FontSize="14"/>
                    </Button>
                    <Button x:Name="ShuffleButton" Style="{StaticResource SubtleButton}" Padding="0" Width="40" Height="40" ToolTip="Shuffle">
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe8b1;" FontSize="14"/>
                    </Button>
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" 
                               Text="{Binding FormattedPosition}" 
                               FontWeight="Light" 
                               FontSize="11" 
                               VerticalAlignment="Center"/>
                    <Slider Grid.Column="1" 
                            Minimum="0" 
                            x:Name="PlayerSlider"
                            IsMoveToPointEnabled="True"
                            Maximum="{Binding Duration}" 
                            Value="{Binding CurrentPosition, Mode=OneWay}"
                            VerticalAlignment="Center" 
                            Margin="8,0" 
                            Height="32"
                            PreviewMouseLeftButtonDown="PlayerSlider_PreviewMouseLeftButtonDown"
                            PreviewMouseLeftButtonUp="PlayerSlider_PreviewMouseLeftButtonUp"
                            />
                    <TextBlock Grid.Column="2" 
                               Text="{Binding FormattedDuration}" 
                               FontWeight="Light" 
                               FontSize="11" 
                               VerticalAlignment="Center"/>
                </Grid>

            </Grid>

            <!--Queue and player info-->
            <StackPanel Orientation="Horizontal" Grid.Column="2" Margin="0,0,8,0" HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                    <Button Style="{StaticResource DefaultButton}" Width="32" Height="32" Padding="1">
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe767;" FontSize="16"/>
                    </Button>
                    <Slider Minimum="0" 
                            Maximum="1" 
                            Value="{Binding Volume, Mode=TwoWay}" 
                            Margin="4,0,8,0" 
                            Width="64" 
                            IsMoveToPointEnabled="True"
                            VerticalAlignment="Center"
                            SmallChange="0.01"
                            LargeChange="0.1"/>
                </StackPanel>
                <Button x:Name="DeviceBtn" 
                        Style="{StaticResource DefaultButton}" 
                        Width="32" Height="32" Padding="1" 
                        Click="DeviceBtn_Click"
                        ToolTip="Device info">
                    <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe7f5;" FontSize="16"/>
                </Button>
                <Popup x:Name="DevicePopup" 
                       PlacementTarget="{Binding ElementName=DeviceBtn}" 
                       Placement="Top" 
                       PopupAnimation="Slide"
                       HorizontalOffset="8"
                       AllowsTransparency="True"
                       StaysOpen="False">
                    <Border>
                        <Border Background="{StaticResource BackgroundFloating}" 
                            BorderBrush="{StaticResource StrokeFloating}" 
                                CornerRadius="8" 
                                Margin="8,16"
                                Width="400"
                                BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000"
                                    BlurRadius="16"
                                    ShadowDepth="4"
                                    Direction="270"
                                    Opacity="0.5"/>
                            </Border.Effect>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="8">
                                    <TextBlock Text="&#xe7f5;" FontFamily="Segoe Fluent Icons" Foreground="White" VerticalAlignment="Center" FontSize="18"/>
                                    <TextBlock Text="Device information" Foreground="White" FontWeight="Medium" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="18"/>
                                </StackPanel>
                                <Separator/>
                                <TextBlock Text="Device info popup" Foreground="White"/>
                            </StackPanel>
                        </Border>
                    </Border>
                </Popup>
                <Button x:Name="QueueBtn" 
                        Style="{StaticResource DefaultButton}" 
                        Width="32" Height="32" Padding="1" 
                        Margin="4,0,0,0" 
                        Click="QueueBtn_Click"
                        ToolTip="Queue">
                    <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe90b;" FontSize="16"/>
                </Button>
                <Popup x:Name="QueuePopup" 
                    PlacementTarget="{Binding ElementName=QueueBtn}" 
                    Placement="Top" 
                    PopupAnimation="Slide"
                    AllowsTransparency="True"
                    HorizontalOffset="8"
                    StaysOpen="False">
                    <Border>
                        <Border Background="{StaticResource BackgroundFloating}" 
                            BorderBrush="{StaticResource StrokeFloating}" 
                            CornerRadius="8" 
                            Margin="8,16"
                            Width="330"
                            Height="600"
                            BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000"
                                    BlurRadius="16"
                                    ShadowDepth="4"
                                    Direction="270"
                                    Opacity="0.5"/>
                            </Border.Effect>
                            <TabControl Margin="0,8,0,0">
                                <TabItem IsSelected="True" >
                                    <TabItem.Header>
                                        <StackPanel Orientation="Horizontal" Margin="8,0">
                                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe768;" VerticalAlignment="Center" />
                                            <TextBlock Text="Now playing" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </StackPanel>
                                    </TabItem.Header>
                                    <Grid>
                                        <mw:QueueListPage />
                                    </Grid>
                                </TabItem>
                                <TabItem IsSelected="True">
                                    <TabItem.Header>
                                        <StackPanel Orientation="Horizontal" Margin="8,0">
                                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe81c;" VerticalAlignment="Center" />
                                            <TextBlock Text="Recently Played" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </StackPanel>
                                    </TabItem.Header>
                                    <Grid>
                                        <TextBlock Margin="12" Text="Is a lie." />
                                    </Grid>
                                </TabItem>
                                <TabItem IsSelected="True">
                                    <TabItem.Header>
                                        <StackPanel Orientation="Horizontal" Margin="8,0">
                                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe713;" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </TabItem.Header>
                                    <Grid>
                                        <TextBlock Margin="12" Text="Is a lie." />
                                    </Grid>
                                </TabItem>
                            </TabControl>
                        </Border>
                    </Border>
                </Popup>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
