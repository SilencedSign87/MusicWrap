<Window x:Class="MusicWrap.UI.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MusicWrap.UI"
        xmlns:pages="clr-namespace:MusicWrap.UI.Pages"
        xmlns:ic="clr-namespace:FluentIcons.Wpf;assembly=FluentIcons.Wpf"
        mc:Ignorable="d"
        Icon="/Resources/icon.ico" 
        Title="MusicWrap" 
        Height="800" 
        Width="1200" 
        MinHeight="600"
        MinWidth="700"
        WindowStartupLocation="CenterScreen"
        d:Background="#000000"
        ResizeMode="CanResize"
        ThemeMode="Dark"
        >
    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="48"
            CornerRadius="12"
            GlassFrameThickness="-1"
            ResizeBorderThickness="4"
            UseAeroCaptionButtons="True"
            NonClientFrameEdges="None"
            />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="TransparentTitleButton" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                >
                            <ContentPresenter HorizontalAlignment="Center" 
                                VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Hover -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BackgroundLayer}"/>
                </Trigger>
                <!-- Pressed -->
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource BackgroundLayerAlt}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CloseTitleButton" TargetType="Button" BasedOn="{StaticResource TransparentTitleButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#C50F1F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <!--Window-->
    <Border
        x:Name="BorderWindow"
        >
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <!--Titlebar-->
            <Grid Grid.Row="0" Margin="0,0,144,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0" HorizontalAlignment="Left" Margin="4">
                    <Image 
                        Source="/Resources/MusicUI.png" 
                        Width="20" 
                        Height="20" 
                        Margin="8,0" 
                        RenderOptions.BitmapScalingMode="HighQuality"
                        />

                    
                    <TabControl
                        Margin="0,4"
                        SelectionChanged="TabControl_SelectionChanged"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        Padding="0"
                        Style="{StaticResource CustomTabControl}">
                        <TabItem Style="{StaticResource CustomTabItem}" TabIndex="0">
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <ic:FluentIcon Icon="Library" FontSize="16" />
                                    <TextBlock Text="Library" Margin="4,0,0,0" FontSize="12" FontWeight="SemiBold"/>
                                </StackPanel>
                            </TabItem.Header>
                        </TabItem>
                        <TabItem Style="{StaticResource CustomTabItem}" TabIndex="1">
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <ic:FluentIcon Icon="ListBar" FontSize="16" />
                                    <TextBlock Text="Playlists" Margin="4,0,0,0" FontSize="12" FontWeight="SemiBold"/>
                                </StackPanel>
                            </TabItem.Header>
                        </TabItem>
                        <TabItem Style="{StaticResource CustomTabItem}" TabIndex="2">
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <ic:FluentIcon Icon="Heart" FontSize="16" />
                                    <TextBlock Text="Favorites" Margin="4,0,0,0" FontSize="12" FontWeight="SemiBold"/>
                                </StackPanel>
                            </TabItem.Header>
                        </TabItem>
                    </TabControl>
                    <Border Margin="4" Width="1" Background="#333">
                    </Border>
                    <Button Style="{StaticResource TransparentTitleButton}" Click="HandleOpenSettings" ToolTip="Settings">
                        <ic:FluentIcon Icon="Settings" FontSize="18"/>
                    </Button>
                    <Button Style="{StaticResource TransparentTitleButton}" Click="HandleOpenMiniPlayer" ToolTip="MiniPlayer">
                        <ic:FluentIcon Icon="ContractDownLeft" FontSize="18"/>
                    </Button>
                    <Border Margin="4" Width="1" Background="#333">
                    </Border>

                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Column="1" ClipToBounds="True" WindowChrome.IsHitTestVisibleInChrome="True">
                   
                    
                </StackPanel>
                
            </Grid>
            <!--Content-->
            <Grid Grid.Row="1">
                <ContentControl
                    x:Name="MainFrame"
                    />
            </Grid>
            <!--Player-->
            <Grid 
                Grid.Row="2"
                Height="80">
                <pages:PlayerPage/>
            </Grid>
        </Grid>
    </Border>
</Window>
