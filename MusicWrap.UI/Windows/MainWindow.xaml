<Window x:Class="MusicWrap.UI.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MusicWrap.UI"
        xmlns:pages="clr-namespace:MusicWrap.UI.Pages"
        mc:Ignorable="d"
        Icon="/Resources/icon.ico" 
        Title="MusicWrap" 
        Height="800" 
        Width="1200" 
        MinHeight="600"
        MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="#222222"
        ResizeMode="CanResize"
        >
    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="48"
            ResizeBorderThickness="8"
            CornerRadius="8"
            GlassFrameThickness="0"
            />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="TransparentTitleButton" TargetType="Button">
            <Setter Property="Height" Value="48" />
            <Setter Property="Width" Value="48" />
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Hover -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3b3b3b"/>
                </Trigger>
                <!-- Pressed -->
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#555555"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CloseTitleButton" TargetType="Button" BasedOn="{StaticResource TransparentTitleButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#C50F1F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <!--Window-->
    <Border
        x:Name="BorderWindow"
        BorderBrush="#454545"
        BorderThickness="1"
        CornerRadius="8"
        >

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <!--Titlebar-->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0" HorizontalAlignment="Left" Margin="8">
                    <Image Source="/Resources/MusicUI.png" Width="18" Height="18" Margin="4,0,8,0" />
                    <TextBlock Text="MusicWrap" VerticalAlignment="Center" FontSize="14" >
                        <TextBlock.Foreground>
                            <RadialGradientBrush>
                                <GradientStop Color="#FFDD7EFE" Offset="0"/>
                                <GradientStop Color="#FF379EE1" Offset="1"/>
                                <GradientStop Color="#FF858EEE" Offset="0.187"/>
                            </RadialGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Column="1" WindowChrome.IsHitTestVisibleInChrome="True" ClipToBounds="True">
                    <TabControl
                        Height="32" 
                        SelectionChanged="TabControl_SelectionChanged"
                        Style="{StaticResource CustomTabControl}">
                        <TabItem Style="{StaticResource CustomTabItem}" TabIndex="0">
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe8f1;" FontSize="18"/>
                                    <TextBlock Text="Library" Margin="4,0,0,0"/>
                                </StackPanel>
                            </TabItem.Header>
                        </TabItem>
                        <TabItem Style="{StaticResource CustomTabItem}" TabIndex="1">
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe8fd;" FontSize="18"/>
                                    <TextBlock Text="Playlists" Margin="4,0,0,0"/>
                                </StackPanel>
                            </TabItem.Header>
                        </TabItem>
                        <TabItem Style="{StaticResource CustomTabItem}" TabIndex="2">
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xeb51;" FontSize="18"/>
                                    <TextBlock Text="Favorites" Margin="4,0,0,0"/>
                                </StackPanel>
                            </TabItem.Header>
                        </TabItem>
                    </TabControl>
                    <Border Margin="4" Width="1" Background="#333">
                    </Border>
                    <Button Style="{StaticResource TransparentTitleButton}" Click="HandleOpenSettings" ToolTip="Settings">
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE713;" FontSize="18"/>
                    </Button>
                    <Button Style="{StaticResource TransparentTitleButton}" Click="HandleOpenMiniPlayer" ToolTip="MiniPlayer">
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xEE49;" FontSize="18"/>
                    </Button>
                    <Border Margin="4" Width="1" Background="#333">
                    </Border>
                    <Button Style="{StaticResource TransparentTitleButton}" Click="MinimizeButtonClick" ToolTip="Minimize">
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE921;" FontSize="10"/>
                    </Button>
                    <Button x:Name="RestoreButton" Style="{StaticResource TransparentTitleButton}" Click="RestoreButtonClick" ToolTip="Maximize">
                        <TextBlock x:Name="RestoreIconFont" FontFamily="Segoe Fluent Icons" Text="&#xE922;" FontSize="10"/>
                    </Button>
                    <Button Style="{StaticResource CloseTitleButton}" Height="48" Click="CloseButtonClick" ToolTip="Close">
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE8bb;" FontSize="10"/>
                    </Button>
                </StackPanel>
            </Grid>
            <!--Content-->
            <Grid Grid.Row="1">
                <ContentControl
                    x:Name="MainFrame"
                    />
            </Grid>
            <!--Player-->
            <Grid 
                Grid.Row="2"
                Height="80">
                <pages:PlayerPage/>
            </Grid>
        </Grid>
    </Border>
</Window>
