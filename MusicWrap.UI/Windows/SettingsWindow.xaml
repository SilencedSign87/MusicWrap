<Window x:Class="MusicWrap.UI.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MusicWrap.UI.Windows"
        xmlns:vm="clr-namespace:MusicWrap.UI.ViewModels.Settings"
        mc:Ignorable="d"
        Title="Settings" 
        Height="700" 
        Width="800"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="#222222"
        ThemeMode="Dark"
        Icon="/Resources/icon.ico"
        >
    <Window.DataContext>
        <vm:SettingsIndexViewModel/>
    </Window.DataContext>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Auto">
            <ListView 
                Background="#1e1e1e" 
                Padding="2"
                SelectedValuePath="Tag"
                SelectedValue="{Binding SelectedTab, Mode=TwoWay}"
                      >
                <ListViewItem Foreground="White" BorderThickness="0" Height="32" Padding="8,0" Tag="general">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe80f;" FontSize="18"/>
                        <TextBlock Text="General" FontSize="14" Margin="8,0,0,0" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem Foreground="White" BorderThickness="0" Height="32" Padding="8,0" Tag="library">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xf12b;" FontSize="18" />
                        <TextBlock Text="Library" FontSize="14" Margin="8,0,0,0" />
                    </StackPanel>
                </ListViewItem>
            </ListView>
        </ScrollViewer>
        <Grid Grid.Column="1">
            <Frame
                x:Name="SettingsFrame"
                NavigationUIVisibility="Hidden"
                />
        </Grid>

    </Grid>
</Window>
