<Window x:Class="MusicWrap.UI.Windows.IndexingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MusicWrap.UI.Windows"
        xmlns:controls="clr-namespace:MusicWrap.UI.Controls"
        xmlns:models="clr-namespace:MusicWrap.UI.Models"
        mc:Ignorable="d"
        Title="Indexer Manager"
        Height="700"
        Width="1000"
        ShowInTaskbar="False"
        ThemeMode="Dark"
        ResizeMode="NoResize"
        Icon="/Resources/icon.ico">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- LEFT PANEL: Tracks List -->
        <Border Grid.Column="0" Grid.Row="0">
            <DockPanel>
                <TextBlock 
                    DockPanel.Dock="Top"
                    Text="Tracks to Index"
                    Padding="8"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Background="{StaticResource BackgroundLayer}"
                        />
                <ListBox
                    DockPanel.Dock="Top"
                    ItemsSource="{Binding StagedTracks}"
                    SelectedItem="{Binding SelectedTrack}"
                    SelectionMode="Extended"
                    SelectionChanged="StagedTracks_SelectionChanged"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    Padding="2">
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Remove selected tracks"
                                          Click="RemoveSelectedTracks_Click"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>

                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="models:StagedTrackNode">
                            <Grid Margin="0" MinHeight="50">
                                <Grid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Remove track"
                                                  Click="RemoveTrack_Click"/>
                                    </ContextMenu>
                                </Grid.ContextMenu>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <!-- Track Index -->
                                <TextBlock
                                    Grid.Column="0"
                                    Text="{Binding Index}"
                                    Foreground="#888888"
                                    FontSize="11"
                                    VerticalAlignment="Center"
                                    Margin="4,0"/>

                                <Border
                                    Grid.Column="1"
                                    Width="48"
                                    Height="48"
                                    VerticalAlignment="Top"
                                    Background="#22000000">
                                    <Image Source="{Binding ThumbnailUrl}" Stretch="UniformToFill"/>
                                </Border>


                                <!-- Track Info -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Top" Margin="4,0">
                                    <TextBlock
                                        Text="{Binding Title}"
                                        Foreground="#ffffff"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        TextTrimming="CharacterEllipsis"/>

                                    <TextBlock
                                        Text="{Binding Artist}"
                                        Foreground="#aaaaaa"
                                        FontSize="11"
                                        TextTrimming="CharacterEllipsis"
                                        Margin="0,2,0,0"/>

                                    <TextBlock
                                        Text="{Binding Album}"
                                        Foreground="#888888"
                                        FontSize="10"
                                        TextTrimming="CharacterEllipsis"
                                        Margin="0,1,0,0"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Foreground" Value="#ffffff"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#3d3d3d"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- RIGHT PANEL: Metadata Editor -->
        <Border Grid.Column="1" Grid.Row="0" Background="{StaticResource BackgroundSmoke}">
            <DockPanel>
                <TextBlock 
                    DockPanel.Dock="Top"
                    Text="Track Metadata"
                    Padding="12,8"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Background="{StaticResource BackgroundLayer}"/>
                <StackPanel Margin="12" Visibility="{Binding HasTrackSelection, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Title" Foreground="#aaaaaa" FontSize="11" Margin="0,0,0,4" FontWeight="SemiBold"/>
                    <TextBox
                        Text="{Binding SelectedTitleValue, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource BaseTextInput}"
                        FontSize="12"/>

                    <TextBlock Text="Artist" Foreground="#aaaaaa" FontSize="11" Margin="0,0,0,4" FontWeight="SemiBold"/>
                    <controls:AutocompleteMetadataInput
                        Text="{Binding SelectedArtistValue, UpdateSourceTrigger=PropertyChanged}"
                        MetadataType="ArtistName"
                        Margin="0,0,0,12"/>

                    <TextBlock Text="Album" Foreground="#aaaaaa" FontSize="11" Margin="0,0,0,4" FontWeight="SemiBold"/>
                    <controls:AutocompleteMetadataInput
                        Text="{Binding SelectedAlbumValue, UpdateSourceTrigger=PropertyChanged}"
                        MetadataType="AlbumTitle"
                        Margin="0,0,0,12"/>

                    <TextBlock Text="Genre" Foreground="#aaaaaa" FontSize="11" Margin="0,0,0,4" FontWeight="SemiBold"/>
                    <controls:AutocompleteMetadataInput
                        Text="{Binding SelectedGenreValue, UpdateSourceTrigger=PropertyChanged}"
                        MetadataType="GenreName"
                        Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Track Number" Foreground="#aaaaaa" FontSize="11" Margin="0,0,0,4" FontWeight="SemiBold"/>
                            <TextBox
                                Style="{StaticResource BaseTextInput}"
                                Text="{Binding SelectedTrackNumberValue, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Disc Number" Foreground="#aaaaaa" FontSize="11" Margin="0,0,0,4" FontWeight="SemiBold"/>
                            <TextBox
                                Style="{StaticResource BaseTextInput}"
                                Text="{Binding SelectedDiscNumberValue, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Year" Foreground="#aaaaaa" FontSize="11" Margin="0,0,0,4" FontWeight="SemiBold"/>
                    <TextBox
                        Style="{StaticResource BaseTextInput}"
                        Text="{Binding SelectedYearValue, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Duration" Foreground="#aaaaaa" FontSize="11" Margin="0,0,0,4" FontWeight="SemiBold"/>
                    <TextBox
                        Style="{StaticResource BaseTextInput}"
                        Text="{Binding SelectedDurationValue, Mode=OneWay}"
                        IsReadOnly="True"/>

                    <TextBlock
                        Margin="0,8"
                        Text="If selected tracks differ on a field, '-- Various Values --' is shown. Editing the field applies to all selected tracks."
                        Foreground="#888888"
                        TextWrapping="Wrap"
                        FontSize="10"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.ColumnSpan="2" Grid.Row="1" Background="{StaticResource BackgroundLayer}" Padding="8,4">
            <ProgressBar
                Height="6"
                Minimum="0"
                Maximum="{Binding IndexingProgressMaximum}"
                Value="{Binding IndexingProgressValue}"
                Visibility="{Binding IsSaving, Converter={StaticResource BooleanToVisibilityConverter}}"
                IsIndeterminate="True"
                Foreground="{StaticResource AccentBrush80}"
                Background="#111111"
                Focusable="False"
                />
        </Border>

        <Border Grid.ColumnSpan="2" Grid.Row="2" Background="{StaticResource BackgroundLayer}" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    Text="{Binding SaveStatusMessage}"
                    VerticalAlignment="Center"
                    Foreground="#aaaaaa"
                    TextTrimming="CharacterEllipsis"
                    FontSize="11"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Margin="8,0"
                            Style="{StaticResource OutlineButton}"
                            Command="{Binding ClearAllStagedTracksCommand}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE74D;" VerticalAlignment="Center"/>
                            <TextBlock Text="Clear entries" Margin="4,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource AccentButton}"
                            Command="{Binding SaveAllStagedTracksCommand}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE74E;" VerticalAlignment="Center"/>
                            <TextBlock Text="Save all entries" Margin="4,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

