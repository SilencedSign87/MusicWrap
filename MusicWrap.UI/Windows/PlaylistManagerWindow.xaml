<Window x:Class="MusicWrap.UI.Windows.PlaylistManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MusicWrap.UI.Windows"
        xmlns:vm="clr-namespace:MusicWrap.UI.ViewModels.Playlist"
        xmlns:controls="clr-namespace:MusicWrap.UI.Controls"
        mc:Ignorable="d"
        Icon="/Resources/icon.ico"
        Title="{Binding SessionTitle}"
        ResizeMode="NoResize"
        d:DataContext="{d:DesignInstance Type=vm:PlaylistManagerViewModel}"
        d:Background="#202020"
        d:Foreground="White"
        Height="500" Width="700">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Create new playlists -->
        <Border Grid.Row="0" Background="{StaticResource BackgroundLayer}">
            <Grid Margin="8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <controls:CompactInputField Grid.Column="0"
                                            PlaceholderText="New playlist..."
                                            VerticalAlignment="Center"
                                            Text="{Binding NewPlaylistName, UpdateSourceTrigger=PropertyChanged}" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource AccentButton}"
                            Command="{Binding CreatePlaylistCommand}">
                        Create
                    </Button>
                    <Button Style="{StaticResource DefaultButton}"
                            Margin="8,0,0,0"
                            Command="{Binding CancelCommand}">
                        Cancel
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tracks to playlists -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition  MinWidth="250" />
                <ColumnDefinition  Width="6" />
                <ColumnDefinition  MinWidth="250"/>
            </Grid.ColumnDefinitions>
            <!-- Tracks in manager session -->
            <Border Grid.Column="0" Background="{StaticResource BackgroundSmoke}" Padding="8">
                <ListView ItemsSource="{Binding Tracks}"
                                  x:Name="TracksListView"
                             Background="Transparent"
                          SelectionMode="Extended"
                             BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             Foreground="White">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Height" Value="auto"/>
                            <Setter Property="Padding" Value="4"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="36">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Image
                                    Source="{Binding ImagePath,  Converter={StaticResource PathToImageConverter}, ConverterParameter=36}"
                                    Width="36"
                                    Height="36"
                                    />
                                <StackPanel Grid.Column="1" Margin="8,0" VerticalAlignment="Center">
                                    <TextBlock FontWeight="SemiBold" FontSize="11" TextTrimming="CharacterEllipsis">
                                        <Run Text="{Binding Title}"/>
                                        <Run Text=" • "/>
                                        <Run Text="{Binding ArtistNames}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding AlbumTitle}" Opacity="0.6" FontSize="10" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding DurationText}"
                                           FontSize="11"
                                           Opacity="0.75"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
            <!-- List of playlists -->
            <Border Grid.Column="2" Background="{StaticResource BackgroundSmoke}" Padding="8">

                <ItemsControl ItemsSource="{Binding Playlists}"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="White">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              IsThreeState="{Binding DataContext.EnablePlaylistTriState, RelativeSource={RelativeSource AncestorType=Window}}"
                                              Content="{Binding Name}" FontSize="12" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </Border>
        </Grid>
    </Grid>
</Window>
