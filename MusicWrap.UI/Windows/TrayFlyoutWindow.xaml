<Window x:Class="MusicWrap.UI.Windows.TrayFlyoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MusicWrap.UI.Windows"
        xmlns:vm="clr-namespace:MusicWrap.UI.ViewModels"
        mc:Ignorable="d"
        Title="Music Wrap" 
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        Height="100" 
        Width="350"
        d:DataContext="{d:DesignInstance Type=vm:PlayerViewModel}"
        >
    <Border Background="{StaticResource BackgroundFloating}" BorderThickness="1" BorderBrush="{StaticResource StrokeFloating}" CornerRadius="4">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Image
                Source="{Binding CurrentTrackImage}"
                Margin="4"
                RenderOptions.BitmapScalingMode="HighQuality"
                />

            <Border Grid.Column="2" Padding="8,8,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="48"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock FontSize="12" TextTrimming="CharacterEllipsis">
                            <Run Text="{Binding CurrentTrackTitle}" />
                            <Run Text=" • "/>
                            <Run Text="{Binding CurrentTrackArtists}" />
                            </TextBlock>
                            <TextBlock FontSize="11">
                            <Run Text="{Binding FormattedPosition}" />
                            <Run Text=" / "/>
                            <Run Text="{Binding FormattedDuration}" />
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <Button Style="{StaticResource TransparentButton}" ToolTip="Open MusicWrap" Click="OpenMainWindow">
                                <TextBlock FontFamily="{StaticResource SymbolThemeFontFamily}" Text="&#xE8A7;"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="RepeadButton" Style="{StaticResource SubtleButton}" Padding="0" Width="40" Height="40" ToolTip="{Binding RepeatModeTooltip}" Command="{Binding CicleRepeatModeCommand}"
        >
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="{Binding RepeatModeIcon}" FontSize="14"/>
                        </Button>
                        <Button x:Name="PrevButton" Style="{StaticResource SubtleButton}" Padding="0" Width="40" Height="40" ToolTip="Previous track" Command="{Binding PreviousCommand}"
        >
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe892;" FontSize="14"/>
                        </Button>
                        <Button x:Name="PlayButton" Style="{StaticResource SubtleButton}" Padding="0" Width="40" Height="40" Command="{Binding PlayPauseCommand}"
        >
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="{Binding PlayPauseIcon}" FontSize="20"/>
                        </Button>
                        <Button x:Name="NextButton" Style="{StaticResource SubtleButton}" Padding="0" Width="40" Height="40" ToolTip="Next track" Command="{Binding NextCommand}"
        >
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe893;" FontSize="14"/>
                        </Button>
                        <Button x:Name="VolumeButton" Click="VolumeButton_Click" Style="{StaticResource SubtleButton}" Padding="0" Width="32" Height="32" ToolTip="Volume">
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe767;" FontSize="14"/>
                        </Button>
                    </StackPanel>
                    <Popup
                        x:Name="VolumePopup"
                        PlacementTarget="{Binding ElementName=VolumeButton}"
                        Placement="Center"
                        PopupAnimation="None"
                        AllowsTransparency="True"
                        StaysOpen="False">
                        <Border>
                            <Border 
                                Background="{StaticResource BackgroundFloating}" 
                                BorderBrush="{StaticResource StrokeFloating}" 
                                CornerRadius="8" 
                                Margin="8,16"
                                Padding="8,4"
                                BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000"
                                        BlurRadius="16"
                                        ShadowDepth="4"
                                        Direction="270"
                                        Opacity="0.5"/>
                                </Border.Effect>
                                <StackPanel>
                                    <Slider
                                        Maximum="1" 
                                        Value="{Binding Volume, Mode=TwoWay}" 
                                        Margin="4,0,8,0" 
                                        IsMoveToPointEnabled="True"
                                        VerticalAlignment="Center"
                                        SmallChange="0.01"
                                        LargeChange="0.1"/>
                                </StackPanel>
                            </Border>
                        </Border>
                    </Popup>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
