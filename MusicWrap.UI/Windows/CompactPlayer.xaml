<Window x:Class="MusicWrap.UI.Windows.CompactPlayer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MusicWrap.UI.Windows"
        xmlns:mw="clr-namespace:MusicWrap.UI.Pages.MainWindow"
        xmlns:controls="clr-namespace:MusicWrap.UI.Controls"
        xmlns:vm="clr-namespace:MusicWrap.UI.ViewModels"
        d:DataContext="{d:DesignInstance Type=vm:PlayerViewModel}"
        mc:Ignorable="d"
        Icon="/Resources/icon.ico" 
        Title="MusicWrap" 
        Width="275" 
        Height="390" 
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Foreground="{Binding CurrentTrackForegroundColorHex, Converter={StaticResource HexToBrushConverter}, ConverterParameter=foreground}"
        d:Background="#2c2c2c"
        >
    <Window.Background>
        <ImageBrush 
            ImageSource="{Binding CurrentTrackImagePath , Converter={StaticResource PathToImageConverter}, ConverterParameter=blur:512}" 
            RenderOptions.BitmapScalingMode="HighQuality"
            Stretch="UniformToFill"/>
    </Window.Background>
    <Window.Resources>
        <Style x:Key="CompactPlayerButton" TargetType="Button" BasedOn="{StaticResource SubtleButton}" >
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Foreground" Value="{Binding CurrentTrackForegroundColorHex, Converter={StaticResource HexToBrushConverter}, ConverterParameter=foreground}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{Binding CurrentTrackDominantColorHex, Converter={StaticResource HexToBrushConverter}, ConverterParameter=background}"/>
                    <Setter Property="Background" Value="{Binding CurrentTrackForegroundColorHex, Converter={StaticResource HexToBrushConverter}, ConverterParameter=foreground}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CompactClosePlayerButton" TargetType="Button" BasedOn="{StaticResource CloseButton}" >
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Foreground" Value="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Window}}"/>
        </Style>
    </Window.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome
        CaptionHeight="275"
        ResizeBorderThickness="6"
        CornerRadius="8"
        GlassFrameThickness="1"
        UseAeroCaptionButtons="False"
        />
    </WindowChrome.WindowChrome>
    <Border
        >
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="275"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <!--Artwork-->
            <Grid Grid.Row="0">
                <Image
                    Source="{Binding CurrentTrackImagePath , Converter={StaticResource PathToImageConverter}, ConverterParameter=large:275}"
                    Width="275"
                    RenderOptions.BitmapScalingMode="HighQuality"
                    />
            </Grid>
            <!--Controls-->
            <Grid Grid.Row="1"
                  >
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="8,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32" />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" 
                            Text="{Binding FormattedPosition}" 
                            FontWeight="Light" 
                            FontSize="11" 
                            VerticalAlignment="Center"/>
                        <Grid Grid.Column="1" Margin="8,4">
                            <controls:WaveformPlayerControl
                                WaveformData="{Binding Waveform}"
                                Position="{Binding CurrentPosition}"
                                Duration="{Binding Duration}"
                                DominantColorHex="{Binding CurrentTrackForegroundColorHex}"
                                SeekStarted="WaveformPlayerControl_SeekStarted"
                                SeekEnded="WaveformPlayerControl_SeekEnded"
                                SeekCanceled="WaveformPlayerControl_SeekCanceled"

                            />
                        </Grid>
                        <TextBlock Grid.Column="2" 
                            Text="{Binding FormattedDuration}" 
                            FontWeight="Light" 
                            FontSize="11" 
                            VerticalAlignment="Center"/>
                    </Grid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="MoreButton" Style="{StaticResource CompactPlayerButton}" Padding="0" ToolTip="Search in library" Click="MoreButton_Click">
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE721;" FontSize="12"/>
                        </Button>
                        <Button x:Name="RepeadButton" Style="{StaticResource CompactPlayerButton}" Padding="0" ToolTip="{Binding RepeatModeTooltip}" Command="{Binding CicleRepeatModeCommand}">
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="{Binding RepeatModeIcon}" FontSize="12"/>
                        </Button>
                        <Button x:Name="PrevButton" Style="{StaticResource CompactPlayerButton}" Padding="0" ToolTip="Previous track"
                            Command="{Binding PreviousCommand}"
                            >
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe892;" FontSize="12"/>
                        </Button>
                        <Button x:Name="PlayButton" Style="{StaticResource CompactPlayerButton}" Padding="0"
                            Command="{Binding PlayPauseCommand}"
                            >
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="{Binding PlayPauseIcon}" FontSize="16"/>
                        </Button>
                        <Button x:Name="NextButton" Style="{StaticResource CompactPlayerButton}" Padding="0" ToolTip="Next track"
                            Command="{Binding NextCommand}"
                            >
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe893;" FontSize="12"/>
                        </Button>
                        <Button x:Name="ShuffleButton" Style="{StaticResource CompactPlayerButton}" Padding="0" ToolTip="{Binding DjTooltip}" Command="{Binding ToggleDJModeCommand}">
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="{Binding DjButtonIcon}" FontSize="12"/>
                        </Button>
                        <Button x:Name="VolumeButton" Click="VolumeButton_Click" Style="{StaticResource CompactPlayerButton}" Padding="0" ToolTip="Volume">
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe767;" FontSize="12"/>
                        </Button>
                    </StackPanel>
                    <Popup
                         x:Name="VolumePopup"
                         PlacementTarget="{Binding ElementName=VolumeButton}"
                         Placement="Center"
                         PopupAnimation="None"
                         AllowsTransparency="True"
                         StaysOpen="False">
                        <Border>
                            <Border 
                                Background="{StaticResource BackgroundFloating}" 
                                BorderBrush="{StaticResource StrokeFloating}" 
                                CornerRadius="8" 
                                Margin="8,16"
                                Padding="8,4"
                                BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000"
                                        BlurRadius="16"
                                        ShadowDepth="4"
                                        Direction="270"
                                        Opacity="0.5"/>
                                </Border.Effect>
                                <StackPanel>
                                    <Slider
                                        Maximum="1" 
                                        Value="{Binding Volume, Mode=TwoWay}" 
                                        Margin="4,0,8,0" 
                                        IsMoveToPointEnabled="True"
                                        VerticalAlignment="Center"
                                        SmallChange="0.01"
                                        LargeChange="0.1"/>
                                </StackPanel>
                            </Border>
                        </Border>

                    </Popup>

                </Grid>
                <Grid Grid.Row="1">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Style="{StaticResource CompactPlayerButton}" Padding="8" ToolTip="Open main player" Click="HandleOpenMainPlayer">
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xEE47;" FontSize="14" />
                        </Button>
                        <Button Style="{StaticResource CompactPlayerButton}" Padding="8" ToolTip="Show Queue" Click="HandleOpenQueue">
                            <TextBlock x:Name="QueueFontIcon" FontFamily="Segoe Fluent Icons" Text="&#xe70d;" FontSize="14" />
                        </Button>
                        <Button Style="{StaticResource CompactPlayerButton}" Padding="8" Click="HandleToggleAllwayOnTop">
                            <TextBlock x:Name="PinIconFont" FontFamily="Segoe Fluent Icons" Text="&#xe718;" FontSize="14" />
                        </Button>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource CompactPlayerButton}" Click="MinimizeClick" Padding="8" ToolTip="Minimize">
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE921;" FontSize="11" />
                        </Button>
                        <Button Style="{StaticResource CompactClosePlayerButton}" Padding="8" Click="HandleCloseApp" ToolTip="Close">
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xe8bb;" FontSize="11" />
                        </Button>
                    </StackPanel>
                </Grid>
                <Grid
                    Grid.Row="2"
                    x:Name="QueuePanel"
                    Visibility="Collapsed"
                    >
                    <mw:QueueListPage />
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
