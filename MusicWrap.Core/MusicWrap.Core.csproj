<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0-windows</TargetFramework>
		<Nullable>enable</Nullable>
		<UseWPF>true</UseWPF>
		<ImplicitUsings>enable</ImplicitUsings>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Un4seen.Bass" Version="2.4.18" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\MusicWrap.Data\MusicWrap.Data.csproj" />
	</ItemGroup>

	<ItemGroup>
		<Reference Include="Un4seen.BassWasapi">
			<HintPath>Native\x64\Un4seen.BassWasapi.dll</HintPath>
			<Private>true</Private>
		</Reference>
	</ItemGroup>
	
	<ItemGroup>
		<None Update="Native\x64\bass.dll">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
			<Link>bass.dll</Link>
		</None>
		<None Update="Native\x64\bassmix.dll">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
			<Link>bassmix.dll</Link>
		</None>
		<None Update="Native\x64\bassflac.dll">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
			<Link>bassflac.dll</Link>
		</None>
		<None Update="Native\x64\basswasapi.dll">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
			<Link>basswasapi.dll</Link>
		</None>
	</ItemGroup>

</Project>
